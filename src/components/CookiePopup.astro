---
// Funny Cookie Consent Popup - Claims we don't use cookies (we don't!)
interface Props {
  lang?: "en" | "el";
}

const { lang = "en" } = Astro.props;

const t = {
  en: {
    title: "🍪 Cookie Notice",
    message: "We removed tracking cookies for performance reasons. We kept the Lotus ones for morale.",
    dismissed: "Close (bring snacks)",
  },
  el: {
    title: "🍪 Σημείωση για Cookies",
    message: "Αφαιρέσαμε τα cookies παρακολούθησης για λόγους απόδοσης. Κρατήσαμε μόνο τα Lotus για το ηθικό της ομάδας.",
    dismissed: "Κλείσιμο (και φέρτε Lotus)",
  },
} as const;

const T = t[lang];
---

<div id="cookie-popup" class="fixed bottom-4 right-4 max-w-sm p-4 rounded-xl bg-white dark:bg-slate-800 border border-amber-200 dark:border-amber-700 shadow-2xl z-50 hidden">
  <div class="flex items-start gap-3">
    <span class="text-3xl">🍪</span>
    <div class="flex-1">
      <h4 class="font-bold text-sm mb-1 text-amber-700 dark:text-amber-400">{T.title}</h4>
      <p class="text-xs text-gray-600 dark:text-slate-400 mb-3">{T.message}</p>
      <button id="cookie-dismiss" class="text-xs bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-300 px-3 py-1.5 rounded-lg hover:bg-amber-200 dark:hover:bg-amber-800/50 transition-colors cursor-pointer">
        {T.dismissed}
      </button>
    </div>
    <button id="cookie-close" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 cursor-pointer" aria-label="Close">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
      </svg>
    </button>
  </div>
</div>

<script is:inline>
  (function() {
    // Check if user has already dismissed the cookie popup
    const hasSeenCookiePopup = localStorage.getItem('cookiePopupDismissed');
    
    if (!hasSeenCookiePopup) {
      // Show popup after a short delay (2 seconds)
      setTimeout(() => {
        const popup = document.getElementById('cookie-popup');
        if (popup) {
          popup.classList.remove('hidden');
          // Add a fun little animation
          popup.style.opacity = '0';
          popup.style.transform = 'translateY(20px)';
          popup.style.transition = 'opacity 0.3s ease, transform 0.3s ease';
          
          requestAnimationFrame(() => {
            popup.style.opacity = '1';
            popup.style.transform = 'translateY(0)';
          });
        }
      }, 2000);
    }
    
    // Dismiss handlers
    function dismissPopup() {
      const popup = document.getElementById('cookie-popup');
      if (popup) {
        popup.style.opacity = '0';
        popup.style.transform = 'translateY(20px)';
        setTimeout(() => {
          popup.classList.add('hidden');
        }, 300);
        
        // Remember that user dismissed it
        localStorage.setItem('cookiePopupDismissed', 'true');
      }
    }
    
    document.getElementById('cookie-dismiss')?.addEventListener('click', dismissPopup);
    document.getElementById('cookie-close')?.addEventListener('click', dismissPopup);
  })();
</script>