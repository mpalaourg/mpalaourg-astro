---
// ─── Build-time only: static assets & translations ──────────────────────────
const BASE = import.meta.env.BASE_URL.replace(/\/$/, "");
const CURRENT_SEASON = new Date().getFullYear();

const TEAM_LOGOS: Record<string, string> = {
  mercedes: `${BASE}/formula/team-logos/mercedes.svg`,
  ferrari: `${BASE}/formula/team-logos/ferrari.svg`,
  red_bull: `${BASE}/formula/team-logos/red_bull.png`,
  mclaren: `${BASE}/formula/team-logos/mclaren.png`,
  alpine: `${BASE}/formula/team-logos/alpine.svg`,
  aston_martin: `${BASE}/formula/team-logos/aston_martin.svg`,
  williams: `${BASE}/formula/team-logos/williams.svg`,
  haas: `${BASE}/formula/team-logos/haas.svg`,
  rb: `${BASE}/formula/team-logos/rb.svg`,
  audi: `${BASE}/formula/team-logos/audi.svg`,
  cadillac: `${BASE}/formula/team-logos/cadillac.svg`,
};

interface Props {
  lang?: "en" | "el";
}
const { lang = "en" } = Astro.props;

const t = {
  en: {
    nextRace: "Next Race",
    pastRace: "Past Race",
    upcoming: "Upcoming",
    round: "Round",
    drivers: "Drivers",
    constructors: "Constructors",
    noRaceData: "No race data available.",
    seasonNotStarted: "Season hasn't started yet",
    driverStandingsEmpty: "Driver standings will appear after Round 1",
    constructorStandingsEmpty:
      "Constructor standings will appear after Round 1",
    days: "days",
    hrs: "hrs",
    min: "min",
    sec: "sec",
    prev: "Prev",
    next: "Next",
    driver: "Driver",
    constructor: "Constructor",
    number: "No",
    points: "Points",
    wins: "Wins",
    pts: "pts",
    loading: "Loading…",
  },
  el: {
    nextRace: "Επόμενος Αγώνας",
    pastRace: "Προηγούμενος Αγώνας",
    upcoming: "Προσεχής",
    round: "Γύρος",
    drivers: "Οδηγοί",
    constructors: "Κατασκευαστές",
    noRaceData: "Δεν υπάρχουν διαθέσιμα δεδομένα αγώνα.",
    seasonNotStarted: "Η σεζόν δεν έχει ξεκινήσει ακόμα",
    driverStandingsEmpty: "Η κατάταξη οδηγών θα εμφανιστεί μετά τον 1ο γύρο",
    constructorStandingsEmpty:
      "Η κατάταξη κατασκευαστών θα εμφανιστεί μετά τον 1ο γύρο",
    days: "μέρες",
    hrs: "ώρες",
    min: "λεπτά",
    sec: "δευτ",
    prev: "Προηγ",
    next: "Επόμενο",
    driver: "Οδηγός",
    constructor: "Κατασκευαστής",
    number: "Αρ",
    points: "Βαθμοί",
    wins: "Νίκες",
    pts: "βαθ",
    loading: "Φόρτωση…",
  },
} as const;

const T = t[lang];
---

<div
  id="f1-widget"
  data-season={CURRENT_SEASON}
  data-labels={JSON.stringify({
    nextRace: T.nextRace,
    pastRace: T.pastRace,
    upcoming: T.upcoming,
    round: T.round,
    pts: T.pts,
    driver: T.driver,
    number: T.number,
    points: T.points,
    wins: T.wins,
    constructor: T.constructor,
    seasonNotStarted: T.seasonNotStarted,
    driverStandingsEmpty: T.driverStandingsEmpty,
    constructorStandingsEmpty: T.constructorStandingsEmpty,
    noRaceData: T.noRaceData,
  })}
  class="rounded-xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-slate-800 p-5 shadow-sm"
>
  {/* Static embedded data — only what can't change at runtime */}
  <script
    id="f1-team-logos"
    type="application/json"
    set:html={JSON.stringify(TEAM_LOGOS)}
  />

  {/* ── Loading skeleton ─────────────────────────────────────────────────── */}
  <div id="f1-loading" class="space-y-3 animate-pulse">
    <div class="flex justify-between items-start gap-4">
      <div class="flex-1 space-y-2">
        <div class="h-4 w-24 rounded-full bg-slate-200 dark:bg-slate-700" />
        <div class="h-6 w-48 rounded bg-slate-200 dark:bg-slate-700" />
        <div class="h-3 w-36 rounded bg-slate-200 dark:bg-slate-700" />
      </div>
      <div class="h-10 w-10 rounded bg-slate-200 dark:bg-slate-700" />
    </div>
    <div class="h-28 rounded-lg bg-slate-200 dark:bg-slate-700" />
    <div class="h-8 rounded bg-slate-200 dark:bg-slate-700" />
  </div>

  {/* ── Main content (hidden until data loads) ───────────────────────────── */}
  <div id="f1-content" class="hidden">
    {/* Header */}
    <div class="flex items-start justify-between gap-4 mb-4">
      <div class="flex-1 min-w-0">
        <div class="flex items-center gap-2 mb-1 flex-wrap">
          <span
            id="f1-badge"
            class="text-xs font-bold px-2 py-0.5 rounded-full bg-red-600 text-white uppercase tracking-wide"
          >
            {T.nextRace}
          </span>
          <span
            id="f1-round"
            class="text-xs text-gray-500 dark:text-slate-400"
          />
        </div>
        <h3 id="f1-race-name" class="text-xl font-bold" />
        <p
          id="f1-circuit-name"
          class="text-sm text-gray-500 dark:text-slate-400"
        />
      </div>
      <div id="f1-flag" class="text-4xl shrink-0" />
    </div>

    {/* Sessions + circuit image */}
    <div class="flex flex-col md:flex-row gap-4 mb-4">
      <div class="flex-1 min-w-0">
        <div class="flex flex-wrap gap-1 mb-3" id="f1-session-tabs" />
        <div class="rounded-lg bg-slate-100 dark:bg-slate-700/50 p-3">
          <p
            id="f1-session-label"
            class="text-xs font-semibold uppercase tracking-wide text-gray-500 dark:text-slate-400 mb-1"
          />
          <p
            id="f1-session-datetime"
            class="text-xs text-gray-500 dark:text-slate-400 mb-2"
          />
          {/* Countdown */}
          <div id="f1-countdown" class="flex gap-3">
            {(
              [
                [T.days, "days"],
                [T.hrs, "hours"],
                [T.min, "mins"],
                [T.sec, "secs"],
              ] as const
            ).map(([label, id], i, arr) => (
              <>
                <div class="text-center">
                  <div
                    id={`cd-${id}`}
                    class="text-2xl font-bold font-mono tabular-nums"
                  >
                    --
                  </div>
                  <div class="text-xs text-gray-500 dark:text-slate-400">
                    {label}
                  </div>
                </div>
                {i < arr.length - 1 && (
                  <div class="text-xl font-bold self-start mt-1">:</div>
                )}
              </>
            ))}
          </div>
          {/* Results panel */}
          <div id="f1-results-panel" class="hidden mt-3" />
        </div>
      </div>

      {/* Circuit image */}
      <div class="md:w-48 shrink-0 flex items-center justify-center rounded-xl bg-slate-100 dark:bg-slate-700/60 p-3">
        <img
          id="f1-circuit-img"
          src=""
          alt="Circuit map"
          class="max-h-40 max-w-full object-contain hidden"
        />
      </div>
    </div>

    {/* Navigation */}
    <div class="flex items-center justify-between mt-2 gap-2">
      <button
        id="f1-prev"
        aria-label="Previous race"
        class="flex items-center gap-1 px-3 py-1.5 rounded-lg text-sm font-medium
               bg-gray-100 dark:bg-slate-700 text-gray-700 dark:text-slate-300
               hover:bg-gray-200 dark:hover:bg-slate-600 disabled:opacity-30
               disabled:cursor-not-allowed transition-colors shrink-0"
      >
        <svg
          class="w-4 h-4"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M15 19l-7-7 7-7"
          />
        </svg>
        {T.prev}
      </button>
      <div
        id="f1-dots"
        class="flex gap-1 flex-wrap justify-center flex-1"
      />
      <button
        id="f1-next"
        aria-label="Next race"
        class="flex items-center gap-1 px-3 py-1.5 rounded-lg text-sm font-medium
               bg-gray-100 dark:bg-slate-700 text-gray-700 dark:text-slate-300
               hover:bg-gray-200 dark:hover:bg-slate-600 disabled:opacity-30
               disabled:cursor-not-allowed transition-colors shrink-0"
      >
        {T.next}
        <svg
          class="w-4 h-4"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M9 5l7 7-7 7"
          />
        </svg>
      </button>
    </div>
  </div>

  {/* ── Error state ───────────────────────────────────────────────────────── */}
  <div id="f1-error" class="hidden text-sm text-gray-500 dark:text-slate-400">
    {T.noRaceData}
  </div>

  {/* ── Standings ─────────────────────────────────────────────────────────── */}
  <div
    id="f1-standings-section"
    class="hidden mt-5 border-t border-gray-200 dark:border-gray-700 pt-4"
  >
    <div class="flex gap-2 mb-3">
      <button
        id="tab-drivers"
        class="px-3 py-1 text-xs font-semibold rounded-full bg-red-600 text-white transition-colors"
      >
        {T.drivers}
      </button>
      <button
        id="tab-constructors"
        class="px-3 py-1 text-xs font-semibold rounded-full bg-gray-200 dark:bg-slate-700 text-gray-700 dark:text-slate-300 hover:bg-gray-300 dark:hover:bg-slate-600 transition-colors"
      >
        {T.constructors}
      </button>
    </div>

    <div id="standings-drivers">
      <div class="py-8 text-center text-sm text-gray-400 dark:text-slate-500 animate-pulse">
        {T.loading}
      </div>
    </div>
    <div id="standings-constructors" class="hidden">
      <div class="py-8 text-center text-sm text-gray-400 dark:text-slate-500 animate-pulse">
        {T.loading}
      </div>
    </div>
  </div>
</div>

{/* ─── Modal ──────────────────────────────────────────────────────────────── */}
<div
  id="f1-modal-backdrop"
  class="fixed inset-0 z-50 hidden items-center justify-center p-4"
  style="background: rgba(0,0,0,0.65); backdrop-filter: blur(3px);"
>
  <div
    id="f1-modal"
    class="relative w-full max-w-lg max-h-[85vh] flex flex-col rounded-2xl
           bg-white dark:bg-slate-800 shadow-2xl
           border border-gray-200 dark:border-gray-700 overflow-hidden"
  >
    <div class="flex items-center justify-between px-5 py-4 border-b border-gray-200 dark:border-gray-700 shrink-0">
      <h2
        id="f1-modal-title"
        class="text-base font-bold text-gray-900 dark:text-white"
      />
      <button
        id="f1-modal-close"
        aria-label="Close"
        class="rounded-lg p-1.5 text-gray-400 hover:text-gray-700 dark:hover:text-white
               hover:bg-gray-100 dark:hover:bg-slate-700 transition-colors"
      >
        <svg
          class="w-5 h-5"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M6 18L18 6M6 6l12 12"
          />
        </svg>
      </button>
    </div>
    <div
      id="f1-modal-body"
      class="overflow-y-auto flex-1 px-5 py-4 space-y-4"
    />
  </div>
</div>

<script>
  // ─── Static constants ──────────────────────────────────────────────────────
  const COUNTRY_FLAGS: Record<string, string> = {
    Australia: "🇦🇺",
    Bahrain: "🇧🇭",
    "Saudi Arabia": "🇸🇦",
    Japan: "🇯🇵",
    China: "🇨🇳",
    USA: "🇺🇸",
    "United States": "🇺🇸",
    Italy: "🇮🇹",
    Monaco: "🇲🇨",
    Canada: "🇨🇦",
    Spain: "🇪🇸",
    Austria: "🇦🇹",
    UK: "🇬🇧",
    "United Kingdom": "🇬🇧",
    Hungary: "🇭🇺",
    Belgium: "🇧🇪",
    Netherlands: "🇳🇱",
    Azerbaijan: "🇦🇿",
    Singapore: "🇸🇬",
    Mexico: "🇲🇽",
    Brazil: "🇧🇷",
    "Las Vegas": "🇺🇸",
    Qatar: "🇶🇦",
    UAE: "🇦🇪",
    "Abu Dhabi": "🇦🇪",
  };

  const BASE = import.meta.env.BASE_URL.replace(/\/$/, "");

  const CIRCUIT_IMAGES: Record<string, string> = {
    albert_park: `${BASE}/formula/circuit-images/albert_park.svg`,
    bahrain: `${BASE}/formula/circuit-images/bahrain.svg`,
    jeddah: `${BASE}/formula/circuit-images/jeddah.svg`,
    suzuka: `${BASE}/formula/circuit-images/suzuka.svg`,
    shanghai: `${BASE}/formula/circuit-images/shanghai.svg`,
    miami: `${BASE}/formula/circuit-images/miami.svg`,
    imola: `${BASE}/formula/circuit-images/imola.svg`,
    monaco: `${BASE}/formula/circuit-images/monaco.svg`,
    villeneuve: `${BASE}/formula/circuit-images/villeneuve.svg`,
    catalunya: `${BASE}/formula/circuit-images/catalunya.svg`,
    red_bull_ring: `${BASE}/formula/circuit-images/red_bull_ring.svg`,
    silverstone: `${BASE}/formula/circuit-images/silverstone.png`,
    hungaroring: `${BASE}/formula/circuit-images/hungaroring.svg`,
    spa: `${BASE}/formula/circuit-images/spa.svg`,
    zandvoort: `${BASE}/formula/circuit-images/zandvoort.png`,
    monza: `${BASE}/formula/circuit-images/monza.svg`,
    baku: `${BASE}/formula/circuit-images/baku.svg`,
    marina_bay: `${BASE}/formula/circuit-images/marina_bay.svg`,
    americas: `${BASE}/formula/circuit-images/americas.svg`,
    rodriguez: `${BASE}/formula/circuit-images/rodriguez.svg`,
    interlagos: `${BASE}/formula/circuit-images/interlagos.svg`,
    vegas: `${BASE}/formula/circuit-images/vegas.svg`,
    losail: `${BASE}/formula/circuit-images/losail.svg`,
    yas_marina: `${BASE}/formula/circuit-images/yas_marina.png`,
    madring: `${BASE}/formula/circuit-images/madrid.svg`,
  };

  // ─── Read embedded static data ─────────────────────────────────────────────
  const TEAM_LOGOS: Record<string, string> = JSON.parse(
    document.getElementById("f1-team-logos")?.textContent ?? "{}"
  );

  const widgetEl = document.getElementById("f1-widget") as HTMLElement;
  const SEASON = parseInt(widgetEl.dataset.season ?? "");
  const LABELS = JSON.parse(widgetEl.dataset.labels ?? "{}");

  // ─── In-memory session cache (avoids duplicate fetches in one page visit) ──
  const sessionCache = new Map<
    string,
    { status: string; results: any[] | null }
  >();

  // ─── Module-level state ────────────────────────────────────────────────────
  let allRaces: any[] = [];
  let nextRaceIndex = 0;
  let currentRaceIndex = 0;
  let sessions: { label: string; date: Date; type: string }[] = [];
  let activeSessionIndex = 0;
  let countdownInterval: ReturnType<typeof setInterval> | null = null;

  // ─── API fetch helpers ─────────────────────────────────────────────────────
  async function fetchSchedule(): Promise<any[]> {
    try {
      const res = await fetch(`/api/f1/schedule?season=${SEASON}`);
      if (!res.ok) return [];
      const data = await res.json();
      return data.races ?? [];
    } catch {
      return [];
    }
  }

  async function fetchStandings(
    type: "drivers" | "constructors"
  ): Promise<any[]> {
    try {
      const res = await fetch(
        `/api/f1/standings?season=${SEASON}&type=${type}`
      );
      if (!res.ok) return [];
      const data = await res.json();
      return data.standings ?? [];
    } catch {
      return [];
    }
  }

  async function fetchSessionResults(
    round: number,
    type: string,
    country: string,
    date: string
  ): Promise<{ status: string; results: any[] | null }> {
    const cacheKey = `${SEASON}-${round}-${type}`;
    if (sessionCache.has(cacheKey)) return sessionCache.get(cacheKey)!;

    try {
      const params = new URLSearchParams({
        season: String(SEASON),
        round: String(round),
        type,
        country,
        date,
      });
      const res = await fetch(`/api/f1/session?${params}`);
      if (!res.ok) return { status: "error", results: null };
      const data = await res.json();
      // Only cache complete results — pending/live should re-fetch next time
      if (data.status === "complete") {
        sessionCache.set(cacheKey, data);
      }
      return data;
    } catch {
      return { status: "error", results: null };
    }
  }

  // ─── General helpers ───────────────────────────────────────────────────────
  const pad = (n: number) => String(n).padStart(2, "0");

  function formatLapTime(seconds: number | null | undefined): string {
    if (seconds == null || isNaN(seconds) || seconds <= 0) return "—";
    const m = Math.floor(seconds / 60);
    const s = seconds % 60;
    return `${m}:${s.toFixed(3).padStart(6, "0")}`;
  }

  function formatLocalDateTime(date: Date): string {
    const base = date.toLocaleString(undefined, {
      weekday: "short",
      day: "numeric",
      month: "short",
      hour: "2-digit",
      minute: "2-digit",
    });
    const off = -date.getTimezoneOffset();
    const sign = off >= 0 ? "+" : "-";
    const abs = Math.abs(off);
    const hh = Math.floor(abs / 60);
    const mm = abs % 60;
    const utc =
      mm === 0 ? `UTC${sign}${hh}` : `UTC${sign}${pad(hh)}:${pad(mm)}`;
    return `${base} (${utc})`;
  }

  /**
   * Given a race object and a session type, return the ISO date string
   * for that session (used as the `date` param in the API call).
   */
  function getSessionDate(race: any, sessionType: string): string {
    const map: Record<string, any> = {
      fp1: race.FirstPractice,
      fp2: race.SecondPractice,
      fp3: race.ThirdPractice,
      sprint_qualifying: race.SprintQualifying,
      sprint: race.Sprint,
      qualifying: race.Qualifying,
      race: { date: race.date, time: race.time },
    };
    return map[sessionType]?.date ?? race.date;
  }

  function buildSessions(
    race: any
  ): { label: string; date: Date; type: string }[] {
    return [
      { label: "FP1", type: "fp1", obj: race.FirstPractice },
      { label: "FP2", type: "fp2", obj: race.SecondPractice },
      { label: "FP3", type: "fp3", obj: race.ThirdPractice },
      {
        label: "Sprint Quali",
        type: "sprint_qualifying",
        obj: race.SprintQualifying,
      },
      { label: "Sprint", type: "sprint", obj: race.Sprint },
      { label: "Qualifying", type: "qualifying", obj: race.Qualifying },
      {
        label: "Race",
        type: "race",
        obj: { date: race.date, time: race.time },
      },
    ]
      .filter((s) => s.obj?.date)
      .map((s) => ({
        label: s.label,
        type: s.type,
        date: s.obj.time
          ? new Date(`${s.obj.date}T${s.obj.time}`)
          : new Date(`${s.obj.date}T00:00:00`),
      }))
      .sort((a, b) => a.date.getTime() - b.date.getTime());
  }

  // ─── Medal / podium styling ────────────────────────────────────────────────
  const MEDAL_CARD = [
    "from-yellow-400/20 to-yellow-300/10 border-yellow-400/40 dark:from-yellow-500/20 dark:border-yellow-500/40",
    "from-slate-300/30 to-slate-200/10 border-slate-300/50 dark:from-slate-400/20 dark:border-slate-400/40",
    "from-orange-400/20 to-orange-300/10 border-orange-400/40 dark:from-orange-500/20 dark:border-orange-500/40",
  ];
  const MEDAL_NUM = [
    "text-yellow-500 dark:text-yellow-400",
    "text-slate-500 dark:text-slate-300",
    "text-orange-500 dark:text-orange-400",
  ];
  const TROPHY = ["🥇", "🥈", "🥉"];

  // Team colors for SVG backgrounds
  const TEAM_COLORS: Record<string, string> = {
    mercedes: "#00A19C",
    ferrari: "#FF0000",
    red_bull: "#1E41FF",
    mclaren: "#FF8000",
    alpine: "#005BA9",
    aston_martin: "#006F62",
    williams: "#00A0DE",
    haas: "#4F4F4F",
    rb: "#1E41FF",
    audi: "#BB0000",
    cadillac: "#000000",
  };

  // Full 2026 grid mapping for driver numbers (for when API doesn't provide them)
  const DRIVER_NUMBERS: Record<string, string> = {
    "Norris": "1",
    "Verstappen": "3",
    "Bortoleto": "5",
    "Hadjar": "6",
    "Gasly": "10",
    "Pérez": "11",
    "Antonelli": "12",
    "Alonso": "14",
    "Leclerc": "16",
    "Stroll": "18",
    "Albon": "23",
    "Hülkenberg": "27",
    "Lawson": "30",
    "Ocon": "31",
    "Lindblad": "41",
    "Colapinto": "43",
    "Hamilton": "44",
    "Sainz": "55",
    "Russell": "63",
    "Bottas": "77",
    "Piastri": "81",
    "Bearman": "87",
  };

  // Helper to get driver number
  function getDriverNumber(driver: any): string {
    // First try API fields
    const apiNumber = driver?.permanentNumber || driver?.number || driver?.driverNumber;
    if (apiNumber) return String(apiNumber);
    
    // Fallback to our mapping by last name
    const lastName = driver?.familyName;
    if (lastName && DRIVER_NUMBERS[lastName]) {
      return DRIVER_NUMBERS[lastName];
    }
    
    return "";
  }

  // Teams that need white logos (logo color matches background)
  const WHITE_LOGO_TEAMS = ["mclaren", "alpine", "williams", "cadillac"];

  // ─── Logo helpers ──────────────────────────────────────────────────────────
  function logoImg(constructorId: string, name: string): string {
    const src = TEAM_LOGOS[constructorId];
    const teamColor = TEAM_COLORS[constructorId] || "#94a3b8";
    const whiteLogo = WHITE_LOGO_TEAMS.includes(constructorId);
    return src
      ? `<span class="inline-flex items-center justify-center h-4 w-6 rounded shrink-0" style="background-color: ${teamColor};"><img src="${src}" alt="${name}" class="h-full w-full object-contain inline-block p-0.5${whiteLogo ? ' brightness-0 invert' : ''}"/></span>`
      : `<span class="inline-block h-2.5 w-2.5 rounded-full bg-slate-400 shrink-0"></span>`;
  }

  // Clean team names - specific mappings for display
  function cleanTeamName(name: string, constructorId: string): string {
    const nameMap: Record<string, string> = {
      "red_bull": "Red Bull Racing",
      "rb": "Racing Bulls",
      "haas": "Haas",
      "alpine": "Alpine",
      "cadillac": "Cadillac",
      "aston_martin": "Aston Martin",
      "mercedes": "Mercedes",
      "ferrari": "Ferrari",
      "mclaren": "McLaren",
      "williams": "Williams",
      "audi": "Audi",
    };
    return nameMap[constructorId] || name.replace(/ F1 Team$/i, "").trim();
  }

  function logoByTeamName(teamName: string): string {
    const t = teamName.toLowerCase();
    const id = t.includes("red bull")
      ? "red_bull"
      : t.includes("ferrari")
        ? "ferrari"
        : t.includes("mercedes")
          ? "mercedes"
          : t.includes("mclaren")
            ? "mclaren"
            : t.includes("alpine")
              ? "alpine"
              : t.includes("aston")
                ? "aston_martin"
                : t.includes("williams")
                  ? "williams"
                  : t.includes("haas")
                    ? "haas"
                    : t.includes("rb") || t.includes("racing bulls")
                      ? "rb"
                      : t.includes("audi") || t.includes("sauber")
                        ? "audi"
                        : t.includes("cadillac") || t.includes("andretti")
                          ? "cadillac"
                          : "";
    return logoImg(id, teamName);
  }

  // ─── Results renderers ─────────────────────────────────────────────────────
  function podiumCards(
    top3: any[],
    getName: (r: any) => string,
    getNumber: (r: any) => string,
    getTeam: (r: any) => string,
    getTeamId: (r: any) => string,
    getTime: (r: any) => string
  ): string {
    if (!top3.length)
      return `<p class="text-xs text-gray-400 dark:text-slate-500 italic">No results yet.</p>`;

    return `<div class="flex gap-2">${top3
      .slice(0, 3)
      .map(
        (r, i) => `
      <div class="flex-1 min-w-0 rounded-xl border bg-gradient-to-b p-2.5 ${MEDAL_CARD[i]}">
        <div class="flex items-center gap-1 mb-1.5">
          <span class="text-base leading-none">${TROPHY[i]}</span>
          <span class="text-xs font-bold ${MEDAL_NUM[i]} tabular-nums ml-auto">#${getNumber(r)}</span>
        </div>
        <p class="text-xs font-bold leading-tight truncate text-gray-900 dark:text-white">${getName(r)}</p>
        <div class="flex items-center gap-1 mt-1">
          ${logoByTeamName(getTeam(r)) || logoImg(getTeamId(r), getTeam(r))}
          <span class="text-[10px] text-gray-500 dark:text-slate-400 truncate">${getTeam(r)}</span>
        </div>
        <p class="text-[10px] font-mono text-gray-600 dark:text-slate-300 mt-1.5 tabular-nums">${getTime(r)}</p>
      </div>`
      )
      .join("")}</div>`;
  }

  function renderOpenF1Podium(rows: any[]): string {
    return podiumCards(
      rows.slice(0, 3),
      (r) => r.name,
      (r) => String(r.driverNumber),
      (r) => r.teamName,
      (_r) => "",
      (r) => r.lapTime
    );
  }

  function renderJolpicaQualiPodium(rows: any[]): string {
    return podiumCards(
      rows.slice(0, 3),
      (r) => `${r.Driver?.givenName?.[0] || ''}. ${r.Driver?.familyName || ''}`,
      (r) => getDriverNumber(r.Driver),
      (r) => r.Constructor?.name ?? "",
      (r) => r.Constructor?.constructorId ?? "",
      (r) => r.Q3 ?? r.Q2 ?? r.Q1 ?? "—"
    );
  }

  function renderJolpicaRacePodium(rows: any[]): string {
    return podiumCards(
      rows.slice(0, 3),
      (r) => `${r.Driver?.givenName?.[0] || ''}. ${r.Driver?.familyName || ''}`,
      (r) => getDriverNumber(r.Driver),
      (r) => r.Constructor?.name ?? "",
      (r) => r.Constructor?.constructorId ?? "",
      (r) => r.Time?.time ?? r.status ?? "—"
    );
  }

  function fullGridBtn(label: string, modalType: string): string {
    return `
      <button
        data-modal="${modalType}"
        class="mt-1 w-full flex items-center justify-center gap-1.5 px-3 py-2 rounded-lg
               text-xs font-semibold bg-slate-100 dark:bg-slate-700
               text-gray-700 dark:text-slate-200
               hover:bg-red-50 dark:hover:bg-slate-600
               border border-gray-200 dark:border-gray-600 transition-colors"
      >
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round"
            d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
        </svg>
        ${label}
      </button>`;
  }

  // ─── Modal body builders ───────────────────────────────────────────────────
  function buildQualiModal(data: any[], isOpenF1 = false): string {
    if (isOpenF1) {
      const sorted = [...data].sort((a, b) => a.position - b.position);
      const q3 = sorted.filter((r) => r.q3 && r.q3 !== "—");
      const q2 = sorted.filter(
        (r) => r.q2 && r.q2 !== "—" && (!r.q3 || r.q3 === "—")
      );
      const q1 = sorted.filter((r) => !r.q2 || r.q2 === "—");

      function of1Section(
        label: string,
        color: string,
        rows: any[],
        timeKey: string
      ) {
        if (!rows.length) return "";
        const rowsHtml = rows
          .map(
            (r) => `
          <div class="grid grid-cols-[1.75rem_1.5rem_1fr_5rem] gap-x-2 px-3 py-2 items-center
                      hover:bg-slate-50 dark:hover:bg-slate-700/50 transition-colors">
            <span class="text-xs font-mono text-gray-400 dark:text-slate-500 text-center">${r.position}</span>
            <span class="text-[10px] font-bold bg-slate-200 dark:bg-slate-600 rounded px-1 py-0.5 tabular-nums text-center">${r.driverNumber}</span>
            <span class="flex items-center gap-1.5 min-w-0">
              ${logoByTeamName(r.teamName)}
              <span class="truncate text-xs font-medium">${r.name}</span>
            </span>
            <span class="text-xs font-mono tabular-nums text-right text-gray-600 dark:text-slate-300">${(r as any)[timeKey] ?? "—"}</span>
          </div>`
          )
          .join("");
        return `
          <div>
            <div class="flex items-center gap-2 mb-1 px-1">
              <span class="text-[10px] font-bold uppercase tracking-widest px-2 py-0.5 rounded-full ${color}">${label}</span>
            </div>
            <div class="rounded-lg border border-gray-200 dark:border-gray-700 overflow-hidden divide-y divide-gray-100 dark:divide-slate-700/50">
              ${rowsHtml}
            </div>
          </div>`;
      }

      return [
        of1Section(
          "Q3 — Top 8",
          "bg-red-100 text-red-700 dark:bg-red-900/40 dark:text-red-300",
          q3,
          "q3"
        ),
        of1Section(
          "Q2 — Out",
          "bg-orange-100 text-orange-700 dark:bg-orange-900/40 dark:text-orange-300",
          q2,
          "q2"
        ),
        of1Section(
          "Q1 — Out",
          "bg-slate-100 text-slate-600 dark:bg-slate-700 dark:text-slate-300",
          q1,
          "q1"
        ),
      ].join("");
    }

    // Regular qualifying from Jolpica
    const sorted = [...data].sort(
      (a, b) => parseInt(a.position) - parseInt(b.position)
    );
    
    // Full 2026 grid - for showing missing drivers
    // Note: Norris uses #1 for 2026 (changed from his permanent #4)
    const full2026Grid = [
      { number: "1", name: "Norris", team: "mclaren" },
      { number: "3", name: "Verstappen", team: "red_bull" },
      { number: "5", name: "Bortoleto", team: "audi" },
      { number: "6", name: "Hadjar", team: "red_bull" },
      { number: "10", name: "Gasly", team: "alpine" },
      { number: "11", name: "Pérez", team: "cadillac" },
      { number: "12", name: "Antonelli", team: "mercedes" },
      { number: "14", name: "Alonso", team: "aston_martin" },
      { number: "16", name: "Leclerc", team: "ferrari" },
      { number: "18", name: "Stroll", team: "aston_martin" },
      { number: "23", name: "Albon", team: "williams" },
      { number: "27", name: "Hülkenberg", team: "audi" },
      { number: "30", name: "Lawson", team: "rb" },
      { number: "31", name: "Ocon", team: "haas" },
      { number: "41", name: "Lindblad", team: "rb" },
      { number: "43", name: "Colapinto", team: "alpine" },
      { number: "44", name: "Hamilton", team: "ferrari" },
      { number: "55", name: "Sainz", team: "williams" },
      { number: "63", name: "Russell", team: "mercedes" },
      { number: "77", name: "Bottas", team: "cadillac" },
      { number: "81", name: "Piastri", team: "mclaren" },
      { number: "87", name: "Bearman", team: "haas" },
    ];
    
    // Find missing drivers (not in results)
    const presentNumbers = new Set(sorted.map(r => r.number || r.Driver?.permanentNumber || r.Driver?.code));
    const missingDrivers = full2026Grid
      .filter(d => !presentNumbers.has(d.number))
      .sort((a, b) => parseInt(a.number) - parseInt(b.number));
    
    // Filter by position, not by whether times exist
    // 2026 format: Top 10 to Q3, positions 11-16 to Q2, positions 17+ out in Q1
    const q3 = sorted.filter((r) => parseInt(r.position) <= 10);
    const q2 = sorted.filter((r) => parseInt(r.position) >= 11 && parseInt(r.position) <= 16);
    const q1 = sorted.filter((r) => parseInt(r.position) >= 17);

    // Parse lap time to seconds for gap calculation
    function parseTime(timeStr: string): number | null {
      if (!timeStr || timeStr === "—" || timeStr === "") return null;
      const parts = timeStr.split(":");
      if (parts.length === 2) {
        const mins = parseFloat(parts[0]);
        const secs = parseFloat(parts[1]);
        return mins * 60 + secs;
      }
      return parseFloat(timeStr);
    }

    // Calculate gaps
    const q3Times = q3.map(r => ({ pos: parseInt(r.position), time: parseTime(r.Q3) })).filter(r => r.time !== null);
    const q2Times = q2.map(r => ({ pos: parseInt(r.position), time: parseTime(r.Q2) })).filter(r => r.time !== null);
    const q1Times = q1.map(r => ({ pos: parseInt(r.position), time: parseTime(r.Q1) })).filter(r => r.time !== null);
    
    // Q3: gap to leader (fastest time in Q3)
    const q3LeaderTime = q3Times.length > 0 ? Math.min(...q3Times.map(r => r.time!)) : null;
    
    // Q2: gap to the driver who was P10 at the end of Q2 (slowest Q2 time among top 10)
    // Sort by Q2 times and find the 10th fastest
    const q2SortedByTime = [...sorted]
      .filter(r => parseTime(r.Q2) !== null)
      .sort((a, b) => parseTime(a.Q2)! - parseTime(b.Q2)!);
    const p10InQ2 = q2SortedByTime[9]; // 10th fastest Q2 time (0-indexed)
    const p10Q2Time = p10InQ2 ? parseTime(p10InQ2.Q2) : null;
    
    // Q1: gap to the driver who was P16 at the end of Q1 (slowest Q1 time among top 16)
    // Sort by Q1 times and find the 16th fastest
    const q1SortedByTime = [...sorted]
      .filter(r => parseTime(r.Q1) !== null)
      .sort((a, b) => parseTime(a.Q1)! - parseTime(b.Q1)!);
    const p16InQ1 = q1SortedByTime[15]; // 16th fastest Q1 time (0-indexed)
    const p16Q1Time = p16InQ1 ? parseTime(p16InQ1.Q1) : null;

    function formatGap(gap: number): string {
      if (gap === 0) return "—";
      return `+${gap.toFixed(3)}`;
    }

    function jSection(
      label: string,
      color: string,
      rows: any[],
      timeKey: string,
      gapType: "leader" | "elimination",
      refTime: number | null,
      extraDrivers: { number: string; name: string; team: string }[] = []
    ) {
      if (!rows.length && !extraDrivers.length) return "";
      
      const rowsHtml = rows
        .map((r) => {
          const isTop3 = parseInt(r.position) <= 3;
          const time = (r as any)[timeKey];
          const timeValue = parseTime(time);
          const hasTime = timeValue !== null;
          let gap = "—";
          
          if (hasTime && refTime !== null) {
            if (gapType === "leader") {
              gap = formatGap(timeValue - refTime);
            } else {
              // For elimination: positive gap means slower than cutoff
              gap = formatGap(timeValue - refTime);
            }
          }
          
          // Format time display
          let timeDisplay: string;
          if (time && time !== "") {
            timeDisplay = time;
          } else {
            // No time set - show in italics
            timeDisplay = "<span class='italic text-gray-400 dark:text-slate-500'>No Time Set</span>";
          }
          
          return `
          <div class="grid grid-cols-[1.75rem_1.5rem_1fr_5.5rem_3.5rem] gap-x-2 px-3 py-2 items-center
                      transition-colors hover:bg-slate-50 dark:hover:bg-slate-700/50
                      ${isTop3 ? "bg-amber-50/60 dark:bg-amber-900/10" : ""}">
            <span class="text-xs font-mono text-gray-400 dark:text-slate-500 text-center">${r.position}</span>
            <span class="text-[10px] font-bold bg-slate-200 dark:bg-slate-600 rounded px-1 py-0.5 tabular-nums text-center">${getDriverNumber(r.Driver) || "—"}</span>
            <span class="flex items-center gap-1.5 min-w-0">
              ${logoImg(r.Constructor?.constructorId ?? "", r.Constructor?.name ?? "")}
              <span class="truncate text-xs font-medium">${r.Driver.givenName[0]}. ${r.Driver.familyName}</span>
            </span>
            <span class="text-xs font-mono tabular-nums text-right text-gray-600 dark:text-slate-300">${timeDisplay}</span>
            <span class="text-[10px] font-mono tabular-nums text-right ${gap === "—" ? "text-gray-400 dark:text-slate-500" : "text-gray-500 dark:text-slate-400"}">${gap}</span>
          </div>`;
        })
        .join("");
      
      // Add missing drivers at the end (for Q1 section)
      const extraRowsHtml = extraDrivers
        .map((d) => `
          <div class="grid grid-cols-[1.75rem_1.5rem_1fr_5.5rem_3.5rem] gap-x-2 px-3 py-2 items-center
                      transition-colors hover:bg-slate-50 dark:hover:bg-slate-700/50 opacity-60">
            <span class="text-xs font-mono text-gray-400 dark:text-slate-500 text-center">—</span>
            <span class="text-[10px] font-bold bg-slate-200 dark:bg-slate-600 rounded px-1 py-0.5 tabular-nums text-center">${d.number}</span>
            <span class="flex items-center gap-1.5 min-w-0">
              ${logoImg(d.team, d.team)}
              <span class="truncate text-xs font-medium">${d.name}</span>
            </span>
            <span class="text-xs font-mono tabular-nums text-right text-gray-400 dark:text-slate-500 italic">No Time Set</span>
            <span class="text-[10px] font-mono tabular-nums text-right text-gray-400 dark:text-slate-500">—</span>
          </div>`)
        .join("");
      
      const gapHeader = gapType === "leader" ? "Gap" : "Gap to Cutoff";
      
      return `
        <div>
          <div class="flex items-center gap-2 mb-1 px-1">
            <span class="text-[10px] font-bold uppercase tracking-widest px-2 py-0.5 rounded-full ${color}">${label}</span>
          </div>
          <div class="rounded-lg border border-gray-200 dark:border-gray-700 overflow-hidden">
            <div class="grid grid-cols-[1.75rem_1.5rem_1fr_5.5rem_3.5rem] gap-x-2 px-3 py-1.5 bg-slate-100 dark:bg-slate-700/50 border-b border-gray-200 dark:border-gray-700">
              <span class="text-[10px] font-semibold text-gray-400 dark:text-slate-500 text-center">#</span>
              <span class="text-[10px] font-semibold text-gray-400 dark:text-slate-500 text-center">No</span>
              <span class="text-[10px] font-semibold text-gray-400 dark:text-slate-500">Driver</span>
              <span class="text-[10px] font-semibold text-gray-400 dark:text-slate-500 text-right">Time</span>
              <span class="text-[10px] font-semibold text-gray-400 dark:text-slate-500 text-right">${gapHeader}</span>
            </div>
            <div class="divide-y divide-gray-100 dark:divide-slate-700/50">
              ${rowsHtml}
              ${extraRowsHtml}
            </div>
          </div>
        </div>`;
    }

    if (q3.length) {
      return [
        jSection(
          "Q3 — Top 10",
          "bg-red-100 text-red-700 dark:bg-red-900/40 dark:text-red-300",
          q3,
          "Q3",
          "leader",
          q3LeaderTime
        ),
        jSection(
          "Q2 — Out",
          "bg-orange-100 text-orange-700 dark:bg-orange-900/40 dark:text-orange-300",
          q2,
          "Q2",
          "elimination",
          p10Q2Time
        ),
        jSection(
          "Q1 — Out",
          "bg-slate-100 text-slate-600 dark:bg-slate-700 dark:text-slate-300",
          q1,
          "Q1",
          "elimination",
          p16Q1Time,
          missingDrivers
        ),
      ].join("");
    }

    return jSection(
      "Full Grid",
      "bg-slate-100 text-slate-600 dark:bg-slate-700 dark:text-slate-300",
      sorted,
      "Q1",
      "leader",
      q1Times.length > 0 ? Math.min(...q1Times.map(r => r.time!)) : null
    );
  }

  function buildRaceModal(data: any[]): string {
    const sorted = [...data].sort(
      (a, b) => parseInt(a.position) - parseInt(b.position)
    );
    
    // Find winner's lap count to calculate laps down for lapped cars
    const winnerLaps = sorted.length > 0 ? parseInt(sorted[0].laps) || 0 : 0;
    
    // Find driver with fastest lap
    let fastestId = null;
    let fastestTime = null;
    for (const r of sorted) {
      if (r.FastestLap && String(r.FastestLap.rank) === "1") {
        fastestId = r.Driver?.driverId;
        fastestTime = r.FastestLap.Time?.time;
        break;
      }
    }

    const header = `
      <div class="grid grid-cols-[1.75rem_1.5rem_1fr_3rem_5.5rem_4.5rem] gap-x-2 px-3 py-1.5
                  bg-slate-100 dark:bg-slate-700/80 rounded-t-lg
                  border border-gray-200 dark:border-gray-700 border-b-0">
        <span class="text-[10px] font-semibold text-gray-400 dark:text-slate-500 text-center">#</span>
        <span class="text-[10px] font-semibold text-gray-400 dark:text-slate-500 text-center">No</span>
        <span class="text-[10px] font-semibold text-gray-400 dark:text-slate-500">Driver</span>
        <span class="text-[10px] font-semibold text-gray-400 dark:text-slate-500 text-center">Laps</span>
        <span class="text-[10px] font-semibold text-gray-400 dark:text-slate-500 text-right">Time</span>
        <span class="text-[10px] font-semibold text-gray-400 dark:text-slate-500 text-right">Status</span>
      </div>`;

    const rows = sorted
      .map((r, i) => {
        const name = `${r.Driver.givenName[0]}. ${r.Driver.familyName}`;
        const cid = r.Constructor?.constructorId ?? "";
        const cname = r.Constructor?.name ?? "";
        const pos = r.positionText || String(i + 1);
        const status = (r.status || "").toString();
        const laps = parseInt(r.laps) || 0;
        
        // DNS: Did Not Start - no laps completed and not classified
        const isDNS = laps === 0 && (status.toLowerCase().includes("did not start") || 
                       status === "DNS" || pos === "DNS" || (!status && !r.Time));
        
        // DNF: Did Not Finish - retired during race
        const isDNF = !isDNS && (["R", "D", "E", "N", "W"].includes(pos) || 
          (!!status && status !== "Finished" && !status.startsWith("+") && 
           !status.toLowerCase().includes("lap") && !isDNS));
        
        // DSQ: Disqualified
        const isDSQ = status === "Disqualified" || status === "DSQ";
        
        // Lapped: Status is "Lapped" or starts with + (e.g., "+1 Lap", "+2 Laps")
        const isLapped = !!status && (status === "Lapped" || status.toLowerCase().includes("lapped") || status.startsWith("+"));
        
        // Calculate laps down for lapped cars (only if not DNF)
        const lapsDown = !isDNF && winnerLaps > 0 && laps > 0 && laps < winnerLaps ? winnerLaps - laps : 0;
        
        // Fastest lap - check if this driver has the fastest lap
        const isFastest = r.Driver?.driverId === fastestId && fastestId;
        
        // Time column
        let timeDisplay = "—";
        if (isDNF) {
          timeDisplay = "—";
        } else if (isLapped && lapsDown > 0) {
          timeDisplay = `+${lapsDown} Lap${lapsDown > 1 ? 's' : ''}`;
        } else if (r.Time?.time) {
          timeDisplay = r.Time.time;
        }
        
        // Status column
        let statusParts = [];
        
        // Check position for podium
        const posNum = parseInt(pos);
        
        if (isDNS) {
          statusParts.push("<span class=\"text-gray-400 dark:text-slate-500\">DNS</span>");
        } else if (isDNF) {
          statusParts.push("<span class=\"text-red-500 dark:text-red-400 font-semibold\">DNF</span>");
        } else if (isDSQ) {
          statusParts.push("<span class=\"text-red-600 dark:text-red-500 font-semibold\">DSQ</span>");
        } else if (isLapped) {
          statusParts.push("<span class=\"text-gray-500 dark:text-slate-400\">Lapped</span>");
        } else if (posNum >= 1 && posNum <= 3) {
          // Podium positions
          const medals = ["🥇", "🥈", "🥉"];
          statusParts.push(`<span class=\"font-bold\">${medals[posNum - 1]} Podium</span>`);
        } else {
          // Regular finishers
          statusParts.push("<span class=\"text-gray-600 dark:text-slate-300\">Finished</span>");
        }
        
        // Add fastest lap bolt (can be combined with other statuses)
        if (isFastest) {
          statusParts.push("<span class=\"text-red-500 dark:text-red-400 font-bold\">⚡</span>");
        }
        
        const statusDisplay = statusParts.join(" ");
        
        const rowBg = isDNF || isDNS || isDSQ
          ? "bg-slate-50 dark:bg-slate-800/50 opacity-60"
          : i === 0
            ? "bg-amber-50/70 dark:bg-amber-900/10"
            : i % 2 === 0
              ? "bg-white dark:bg-slate-800"
              : "bg-slate-50 dark:bg-slate-700/30";

        return `
        <div class="grid grid-cols-[1.75rem_1.5rem_1fr_3rem_5.5rem_4.5rem] gap-x-2 px-3 py-2 items-center
                    transition-colors hover:bg-red-50 dark:hover:bg-slate-700/50 ${rowBg}">
          <span class="text-xs font-mono ${isDNF || isDNS || isDSQ ? "text-gray-300 dark:text-slate-600" : "text-gray-400 dark:text-slate-500"} text-center">${pos}</span>
          <span class="text-[10px] font-bold bg-slate-200 dark:bg-slate-600 rounded px-1 py-0.5 tabular-nums text-center">${getDriverNumber(r.Driver)}</span>
          <span class="flex items-center gap-1.5 min-w-0">
            ${logoImg(cid, cname)}
            <span class="truncate text-xs font-medium">${name}</span>
          </span>
          <span class="text-xs tabular-nums text-center text-gray-500 dark:text-slate-400">${laps || "—"}</span>
          <span class="text-xs font-mono tabular-nums text-right text-gray-600 dark:text-slate-300">${timeDisplay}</span>
          <span class="text-xs font-mono tabular-nums text-right">${statusDisplay}</span>
        </div>`;
      })
      .join("");

    return `
      <div>
        ${header}
        <div class="rounded-b-lg border border-gray-200 dark:border-gray-700 border-t-0 overflow-hidden divide-y divide-gray-100 dark:divide-slate-700/50">
          ${rows}
        </div>
        <p class="text-[10px] text-gray-400 dark:text-slate-500 mt-2 text-right">⚡ = Fastest Lap</p>
      </div>`;
  }

  // ─── Standings renderers (now client-side) ─────────────────────────────────
  function renderDriverStandings(standings: any[]): void {
    const container = document.getElementById("standings-drivers")!;

    if (!standings.length) {
      container.innerHTML = `
        <div class="flex flex-col items-center justify-center py-8 text-center gap-2">
          <span class="text-2xl">🏎️</span>
          <p class="text-sm font-medium text-gray-500 dark:text-slate-400">${LABELS.seasonNotStarted}</p>
          <p class="text-xs text-gray-400 dark:text-slate-500">${LABELS.driverStandingsEmpty}</p>
        </div>`;
      return;
    }

    const header = `
      <div class="grid grid-cols-[2rem_2rem_1fr_3.5rem_2.5rem] gap-x-2 px-3 py-1.5
                  bg-slate-100 dark:bg-slate-700/80 border-b border-gray-200 dark:border-gray-700">
        <span class="text-xs font-semibold text-gray-400 dark:text-slate-500 text-center">#</span>
        <span class="text-xs font-semibold text-gray-400 dark:text-slate-500 text-center">${LABELS.number}</span>
        <span class="text-xs font-semibold text-gray-400 dark:text-slate-500">${LABELS.driver}</span>
        <span class="text-xs font-semibold text-gray-400 dark:text-slate-500 text-right">${LABELS.points}</span>
        <span class="text-xs font-semibold text-gray-400 dark:text-slate-500 text-right">${LABELS.wins}</span>
      </div>`;

    const rows = standings
      .map((d, i) => {
        const cid = d.Constructors[0]?.constructorId ?? "";
        const logo = TEAM_LOGOS[cid];
        const teamColor = TEAM_COLORS[cid] || "#94a3b8";
        const whiteLogo = WHITE_LOGO_TEAMS.includes(cid);
        const logoHtml = logo
          ? `<span class="inline-flex items-center justify-center h-5 w-7 rounded shrink-0" style="background-color: ${teamColor};"><img src="${logo}" alt="${d.Constructors[0]?.name}" class="h-full w-full object-contain p-0.5${whiteLogo ? ' brightness-0 invert' : ''}"/></span>`
          : `<span class="h-3 w-3 rounded-full shrink-0 bg-slate-400"></span>`;
        const rowBg =
          i % 2 === 0
            ? "bg-white dark:bg-slate-800"
            : "bg-slate-50 dark:bg-slate-700/40";
        const position = d.position || String(i + 1);
        const driverNumber = getDriverNumber(d.Driver);
        return `
        <div class="grid grid-cols-[2rem_2rem_1fr_3.5rem_2.5rem] gap-x-2 px-3 py-2 items-center
                    transition-colors hover:bg-red-50 dark:hover:bg-slate-700/40 ${rowBg}">
          <span class="text-xs text-gray-400 dark:text-slate-500 font-mono text-center">${position}</span>
          <span class="text-xs font-bold text-center bg-slate-200 dark:bg-slate-700 rounded px-1 py-0.5 tabular-nums">${driverNumber}</span>
          <span class="flex items-center gap-2 min-w-0">
            ${logoHtml}
            <span class="truncate text-sm font-medium">${d.Driver.givenName[0]}. ${d.Driver.familyName}</span>
          </span>
          <span class="text-sm font-bold tabular-nums text-right">${d.points}</span>
          <span class="text-xs text-gray-400 dark:text-slate-500 text-right tabular-nums">${d.wins}</span>
        </div>`;
      })
      .join("");

    container.innerHTML = `
      <div class="overflow-hidden rounded-lg border border-gray-200 dark:border-gray-700">
        ${header}
        <div class="max-h-64 overflow-y-auto divide-y divide-gray-100 dark:divide-slate-700/50">
          ${rows}
        </div>
      </div>`;
  }

  function renderConstructorStandings(
    constructors: any[],
    drivers: any[]
  ): void {
    const container = document.getElementById("standings-constructors")!;

    if (!constructors.length) {
      container.innerHTML = `
        <div class="flex flex-col items-center justify-center py-8 text-center gap-2">
          <span class="text-2xl">🏗️</span>
          <p class="text-sm font-medium text-gray-500 dark:text-slate-400">${LABELS.seasonNotStarted}</p>
          <p class="text-xs text-gray-400 dark:text-slate-500">${LABELS.constructorStandingsEmpty}</p>
        </div>`;
      return;
    }

    const totalPts = constructors.reduce(
      (s, c) => s + parseFloat(c.points),
      0
    );

    const header = `
      <div class="grid grid-cols-[2rem_1fr_3.5rem_2.5rem] gap-x-2 px-3 py-1.5
                  bg-slate-100 dark:bg-slate-700/80 border-b border-gray-200 dark:border-gray-700">
        <span class="text-xs font-semibold text-gray-400 dark:text-slate-500 text-center">#</span>
        <span class="text-xs font-semibold text-gray-400 dark:text-slate-500">${LABELS.constructor}</span>
        <span class="text-xs font-semibold text-gray-400 dark:text-slate-500 text-right">${LABELS.points}</span>
        <span class="text-xs font-semibold text-gray-400 dark:text-slate-500 text-right">${LABELS.wins}</span>
      </div>`;

    const rows = constructors
      .filter((c) => c.Constructor && c.Constructor.constructorId)
      .map((c, i) => {
        const logo = TEAM_LOGOS[c.Constructor.constructorId];
        const teamColor = TEAM_COLORS[c.Constructor.constructorId] || "#94a3b8";
        const whiteLogo = WHITE_LOGO_TEAMS.includes(c.Constructor.constructorId);
        const logoHtml = logo
          ? `<span class="inline-flex items-center justify-center h-5 w-7 rounded shrink-0" style="background-color: ${teamColor};"><img src="${logo}" alt="${c.Constructor.name}" class="h-full w-full object-contain p-0.5${whiteLogo ? ' brightness-0 invert' : ''}"/></span>`
          : `<span class="h-3 w-3 rounded-full shrink-0 bg-slate-400"></span>`;
        const rowBg =
          i % 2 === 0
            ? "bg-white dark:bg-slate-800"
            : "bg-slate-50 dark:bg-slate-700/40";

        // Build per-driver sub-rows
        const constructorDrivers = drivers
          .filter((d) =>
            d.Constructors.some(
              (co: any) => co.name === c.Constructor.name
            )
          )
          .map((d) => {
            const dPts = parseFloat(d.points);
            const cPts = parseFloat(c.points);
            const pct =
              totalPts > 0 && cPts > 0
                ? ((dPts / cPts) * 100).toFixed(0)
                : "0";
            return { name: `${d.Driver.givenName[0]}. ${d.Driver.familyName}`, points: d.points, pct };
          });

        const driverRows = constructorDrivers
          .map(
            (drv) => `
          <div class="flex items-center gap-2 text-xs text-gray-500 dark:text-slate-400">
            <span class="flex-1 truncate">${drv.name}</span>
            <span class="tabular-nums font-medium">${drv.points} ${LABELS.pts}</span>
            <div class="w-20 flex items-center gap-1">
              <div class="flex-1 h-1 rounded-full bg-slate-200 dark:bg-slate-600 overflow-hidden">
                <div class="h-full rounded-full bg-red-400 dark:bg-red-500" style="width: ${drv.pct}%"></div>
              </div>
              <span class="w-7 text-right tabular-nums text-gray-400 dark:text-slate-500">${drv.pct}%</span>
            </div>
          </div>`
          )
          .join("");

        const position = c.position || String(i + 1);

        return `
        <div class="${rowBg}">
          <div class="grid grid-cols-[2rem_1fr_3.5rem_2.5rem] gap-x-2 px-3 py-2 items-center
                      transition-colors hover:bg-red-50 dark:hover:bg-slate-700/40">
            <span class="text-xs text-gray-400 dark:text-slate-500 font-mono text-center">${position}</span>
            <span class="flex items-center gap-2 min-w-0">
              ${logoHtml}
              <span class="truncate text-sm font-semibold">${cleanTeamName(c.Constructor.name, c.Constructor.constructorId)}</span>
            </span>
            <span class="text-sm font-bold tabular-nums text-right">${c.points}</span>
            <span class="text-xs text-gray-400 dark:text-slate-500 text-right tabular-nums">${c.wins}</span>
          </div>
          ${constructorDrivers.length ? `<div class="pb-1.5 px-3 ml-8 space-y-0.5">${driverRows}</div>` : ""}
        </div>`;
      })
      .join("");

    container.innerHTML = `
      <div class="overflow-hidden rounded-lg border border-gray-200 dark:border-gray-700">
        ${header}
        <div class="max-h-64 overflow-y-auto divide-y divide-gray-100 dark:divide-slate-700/50">
          ${rows}
        </div>
      </div>`;
  }

  // ─── Results panel ─────────────────────────────────────────────────────────
  async function showResults(
    session: { label: string; type: string },
    race: any
  ): Promise<void> {
    const panel = document.getElementById("f1-results-panel")!;
    panel.innerHTML = `<p class="text-xs text-gray-400 dark:text-slate-500 italic animate-pulse">Loading results…</p>`;
    panel.classList.remove("hidden");

    const country = race.Circuit?.Location?.country ?? "";
    const date = getSessionDate(race, session.type);

    const { status, results } = await fetchSessionResults(
      parseInt(race.round),
      session.type,
      country,
      date
    );

    if (status === "live") {
      panel.innerHTML = `<p class="text-xs text-orange-500 dark:text-orange-400 font-semibold">🔴 Session in progress — check back shortly</p>`;
      return;
    }

    if (!results?.length) {
      panel.innerHTML = `<p class="text-xs text-gray-400 dark:text-slate-500 italic">Results not yet available.</p>`;
      return;
    }

    const type = session.type;
    let html = "";

    if (type === "fp1" || type === "fp2" || type === "fp3") {
      html = renderOpenF1Podium(results);
    } else if (type === "sprint_qualifying") {
      html =
        renderOpenF1Podium(results) +
        fullGridBtn("Full Sprint Qualifying Grid", "sprint_qualifying");
    } else if (type === "qualifying") {
      html =
        renderJolpicaQualiPodium(results) +
        fullGridBtn("Full Qualifying Grid", "qualifying");
    } else if (type === "sprint") {
      html =
        renderJolpicaRacePodium(results) +
        fullGridBtn("Full Sprint Results", "sprint");
    } else if (type === "race") {
      html =
        renderJolpicaRacePodium(results) +
        fullGridBtn("Full Race Results", "race");
    }

    panel.innerHTML = html;

    // Wire up the "full grid" modal button if present
    const btn = panel.querySelector<HTMLButtonElement>("button[data-modal]");
    if (btn) {
      btn.addEventListener("click", () => {
        const modalType = btn.dataset.modal!;
        const title =
          modalType === "qualifying"
            ? `${race.raceName} — Qualifying`
            : modalType === "sprint_qualifying"
              ? `${race.raceName} — Sprint Qualifying`
              : modalType === "sprint"
                ? `${race.raceName} — Sprint`
                : `${race.raceName} — Race Results`;

        const isOpenF1Quali = modalType === "sprint_qualifying";
        const isQuali =
          modalType === "qualifying" || modalType === "sprint_qualifying";
        const body = isQuali
          ? buildQualiModal(results, isOpenF1Quali)
          : buildRaceModal(results);

        openModal(title, body);
      });
    }
  }

  function hideResults(): void {
    const panel = document.getElementById("f1-results-panel")!;
    panel.classList.add("hidden");
    panel.innerHTML = "";
  }

  // ─── Modal controls ────────────────────────────────────────────────────────
  const backdrop = document.getElementById(
    "f1-modal-backdrop"
  ) as HTMLDivElement;
  const modalTitle = document.getElementById("f1-modal-title")!;
  const modalBody = document.getElementById("f1-modal-body")!;

  function openModal(title: string, body: string): void {
    modalTitle.textContent = title;
    modalBody.innerHTML = body;
    backdrop.classList.remove("hidden");
    backdrop.classList.add("flex");
    document.body.style.overflow = "hidden";
  }

  function closeModal(): void {
    backdrop.classList.add("hidden");
    backdrop.classList.remove("flex");
    document.body.style.overflow = "";
  }

  document
    .getElementById("f1-modal-close")!
    .addEventListener("click", closeModal);
  backdrop.addEventListener("click", (e) => {
    if (e.target === backdrop) closeModal();
  });
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeModal();
  });

  // ─── Countdown ─────────────────────────────────────────────────────────────
  function startCountdown(
    targetDate: Date,
    session: { label: string; type: string },
    race: any
  ): void {
    if (countdownInterval) clearInterval(countdownInterval);

    function tick() {
      const diff = targetDate.getTime() - Date.now();
      if (diff <= 0) {
        ["days", "hours", "mins", "secs"].forEach(
          (id) => ((document.getElementById(`cd-${id}`)!.textContent = "00"))
        );
        clearInterval(countdownInterval!);
        void showResults(session, race);
        return;
      }
      document.getElementById("cd-days")!.textContent = pad(
        Math.floor(diff / 86400000)
      );
      document.getElementById("cd-hours")!.textContent = pad(
        Math.floor((diff % 86400000) / 3600000)
      );
      document.getElementById("cd-mins")!.textContent = pad(
        Math.floor((diff % 3600000) / 60000)
      );
      document.getElementById("cd-secs")!.textContent = pad(
        Math.floor((diff % 60000) / 1000)
      );
    }
    tick();
    countdownInterval = setInterval(tick, 1000);
  }

  // ─── Session tabs ───────────────────────────────────────────────────────────
  function renderSessionTabs(race: any): void {
    const container = document.getElementById("f1-session-tabs")!;
    container.innerHTML = "";
    sessions.forEach((session, i) => {
      const isActive = i === activeSessionIndex;
      const btn = document.createElement("button");
      btn.textContent = session.label;
      btn.className = [
        "px-2 py-1 text-xs rounded-md font-medium transition-colors",
        isActive
          ? "bg-red-600 text-white"
          : "bg-gray-200 dark:bg-slate-700 text-gray-700 dark:text-slate-300 hover:bg-gray-300 dark:hover:bg-slate-600",
      ].join(" ");
      btn.addEventListener("click", () => {
        activeSessionIndex = i;
        renderSessionTabs(race);
        updateSessionDisplay(race);
      });
      container.appendChild(btn);
    });
  }

  function updateSessionDisplay(race: any): void {
    const session = sessions[activeSessionIndex];
    if (!session) return;

    document.getElementById("f1-session-label")!.textContent = session.label;
    document.getElementById("f1-session-datetime")!.textContent =
      formatLocalDateTime(session.date);

    const isPast = session.date.getTime() < Date.now();
    if (isPast) {
      ["days", "hours", "mins", "secs"].forEach(
        (id) => ((document.getElementById(`cd-${id}`)!.textContent = "00"))
      );
      if (countdownInterval) clearInterval(countdownInterval);
      void showResults(session, race);
    } else {
      hideResults();
      startCountdown(session.date, session, race);
    }
  }

  // ─── Navigation dots ────────────────────────────────────────────────────────
  function renderDots(): void {
    const container = document.getElementById("f1-dots")!;
    const now = Date.now();
    container.innerHTML = "";
    allRaces.forEach((r, i) => {
      const ms = new Date(`${r.date}T${r.time ?? "00:00:00"}`).getTime();
      const dot = document.createElement("button");
      dot.setAttribute("aria-label", `Round ${i + 1}: ${r.raceName}`);
      dot.className = [
        "w-2 h-2 rounded-full transition-all duration-200 focus:outline-none",
        i === currentRaceIndex
          ? "bg-red-500 scale-125"
          : i === nextRaceIndex
            ? "bg-orange-400"
            : ms < now
              ? "bg-slate-400 dark:bg-slate-500"
              : "bg-slate-300 dark:bg-slate-600",
      ].join(" ");
      dot.addEventListener("click", () => {
        currentRaceIndex = i;
        renderRace();
      });
      container.appendChild(dot);
    });
  }

  // ─── Main race render ───────────────────────────────────────────────────────
  function renderRace(): void {
    const race = allRaces[currentRaceIndex];
    if (!race) return;

    const raceMs = new Date(
      `${race.date}T${race.time ?? "00:00:00"}`
    ).getTime();
    const now = Date.now();
    const isNext = currentRaceIndex === nextRaceIndex;
    const isPast = raceMs < now;

    // Badge
    const badge = document.getElementById("f1-badge")!;
    if (isNext) {
      badge.textContent = LABELS.nextRace;
      badge.className =
        "text-xs font-bold px-2 py-0.5 rounded-full bg-red-600 text-white uppercase tracking-wide";
    } else if (isPast) {
      badge.textContent = LABELS.pastRace;
      badge.className =
        "text-xs font-bold px-2 py-0.5 rounded-full bg-slate-500 text-white uppercase tracking-wide";
    } else {
      badge.textContent = LABELS.upcoming;
      badge.className =
        "text-xs font-bold px-2 py-0.5 rounded-full bg-orange-500 text-white uppercase tracking-wide";
    }

    document.getElementById("f1-round")!.textContent =
      `${race.season} · ${LABELS.round} ${race.round}`;
    document.getElementById("f1-race-name")!.textContent = race.raceName;
    document.getElementById("f1-circuit-name")!.textContent =
      `${race.Circuit.circuitName}, ${race.Circuit.Location.locality}`;
    document.getElementById("f1-flag")!.textContent =
      COUNTRY_FLAGS[race.Circuit.Location.country] ?? "🏁";

    // Circuit image
    const imgEl = document.getElementById(
      "f1-circuit-img"
    ) as HTMLImageElement;
    imgEl.onload = null;
    imgEl.onerror = null;
    imgEl.classList.add("hidden");
    const imgSrc = CIRCUIT_IMAGES[race.Circuit.circuitId];
    if (imgSrc) {
      imgEl.onload = () => imgEl.classList.remove("hidden");
      imgEl.onerror = () => imgEl.classList.add("hidden");
      imgEl.src = imgSrc;
      imgEl.alt = `${race.raceName} circuit map`;
    }

    // Sessions
    sessions = buildSessions(race);
    const upcomingIdx = sessions.findIndex((s) => s.date.getTime() > now);
    activeSessionIndex = upcomingIdx >= 0 ? upcomingIdx : sessions.length - 1;
    renderSessionTabs(race);
    updateSessionDisplay(race);

    // Nav buttons
    (document.getElementById("f1-prev") as HTMLButtonElement).disabled =
      currentRaceIndex === 0;
    (document.getElementById("f1-next") as HTMLButtonElement).disabled =
      currentRaceIndex === allRaces.length - 1;

    renderDots();
  }

  // ─── Tab switching ──────────────────────────────────────────────────────────
  const activeTabCls = "bg-red-600 text-white";
  const inactiveTabCls =
    "bg-gray-200 dark:bg-slate-700 text-gray-700 dark:text-slate-300 hover:bg-gray-300 dark:hover:bg-slate-600";
  const tabBase = "px-3 py-1 text-xs font-semibold rounded-full transition-colors";

  document.getElementById("tab-drivers")!.addEventListener("click", () => {
    document.getElementById("standings-drivers")!.classList.remove("hidden");
    document
      .getElementById("standings-constructors")!
      .classList.add("hidden");
    document.getElementById("tab-drivers")!.className =
      `${tabBase} ${activeTabCls}`;
    document.getElementById("tab-constructors")!.className =
      `${tabBase} ${inactiveTabCls}`;
  });
  document
    .getElementById("tab-constructors")!
    .addEventListener("click", () => {
      document
        .getElementById("standings-constructors")!
        .classList.remove("hidden");
      document.getElementById("standings-drivers")!.classList.add("hidden");
      document.getElementById("tab-constructors")!.className =
        `${tabBase} ${activeTabCls}`;
      document.getElementById("tab-drivers")!.className =
        `${tabBase} ${inactiveTabCls}`;
    });

  document.getElementById("f1-prev")!.addEventListener("click", () => {
    if (currentRaceIndex > 0) {
      currentRaceIndex--;
      renderRace();
    }
  });
  document.getElementById("f1-next")!.addEventListener("click", () => {
    if (currentRaceIndex < allRaces.length - 1) {
      currentRaceIndex++;
      renderRace();
    }
  });

  // ─── Init ───────────────────────────────────────────────────────────────────
  async function init(): Promise<void> {
    // Fetch schedule + both standings in parallel
    const [races, driverStandings, constructorStandings] = await Promise.all([
      fetchSchedule(),
      fetchStandings("drivers"),
      fetchStandings("constructors"),
    ]);

    // Hide skeleton
    document.getElementById("f1-loading")!.classList.add("hidden");

    if (!races.length) {
      document.getElementById("f1-error")!.classList.remove("hidden");
      return;
    }

    // Set global races + find next race
    allRaces = races;
    const now = Date.now();
    const idx = allRaces.findIndex(
      (r) => new Date(`${r.date}T${r.time ?? "00:00:00"}`).getTime() > now
    );
    nextRaceIndex = idx >= 0 ? idx : allRaces.length - 1;
    currentRaceIndex = nextRaceIndex;

    // Show main content
    document.getElementById("f1-content")!.classList.remove("hidden");
    document
      .getElementById("f1-standings-section")!
      .classList.remove("hidden");

    // Render
    renderRace();
    renderDriverStandings(driverStandings);
    renderConstructorStandings(constructorStandings, driverStandings);
  }

  init();
</script>