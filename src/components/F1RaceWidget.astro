  // ─── Modal body builders ──────────────────────────────────────────────────

  function buildQualiModal(data: any[], isOpenF1 = false): string {
    if (isOpenF1) {
      // Sprint Qualifying from OpenF1
      const sorted = [...data].sort((a, b) => a.position - b.position);
      const q3 = sorted.filter((r) => r.q3 && r.q3 !== "—");
      const q2 = sorted.filter((r) => r.q2 && r.q2 !== "—" && (!r.q3 || r.q3 === "—"));
      const q1 = sorted.filter((r) => !r.q2 || r.q2 === "—");

      function of1Section(label: string, color: string, rows: any[], timeKey: string) {
        if (!rows.length) return "";
        const rowsHtml = rows.map((r) => `
          <div class="grid grid-cols-[1.75rem_1.5rem_1fr_5rem] gap-x-2 px-3 py-2 items-center
                      hover:bg-slate-50 dark:hover:bg-slate-700/50 transition-colors">
            <span class="text-xs font-mono text-gray-400 dark:text-slate-500 text-center">${r.position}</span>
            <span class="text-[10px] font-bold bg-slate-200 dark:bg-slate-600 rounded px-1 py-0.5 tabular-nums text-center">${r.driverNumber}</span>
            <span class="flex items-center gap-1.5 min-w-0">
              ${logoByTeamName(r.teamName)}
              <span class="truncate text-xs font-medium">${r.name}</span>
            </span>
            <span class="text-xs font-mono tabular-nums text-right text-gray-600 dark:text-slate-300">${(r as any)[timeKey] ?? "—"}</span>
          </div>`).join("");
        return `
          <div>
            <div class="flex items-center gap-2 mb-1 px-1">
              <span class="text-[10px] font-bold uppercase tracking-widest px-2 py-0.5 rounded-full ${color}">${label}</span>
            </div>
            <div class="rounded-lg border border-gray-200 dark:border-gray-700 overflow-hidden divide-y divide-gray-100 dark:divide-slate-700/50">
              ${rowsHtml}
            </div>
          </div>`;
      }

      return [
        of1Section("Q3 — Top 8", "bg-red-100 text-red-700 dark:bg-red-900/40 dark:text-red-300", q3, "q3"),
        of1Section("Q2 — Out", "bg-orange-100 text-orange-700 dark:bg-orange-900/40 dark:text-orange-300", q2, "q2"),
        of1Section("Q1 — Out", "bg-slate-100 text-slate-600 dark:bg-slate-700 dark:text-slate-300", q1, "q1"),
      ].join("");
    }

    // Regular qualifying from Jolpica
    const sorted = [...data].sort(
      (a, b) => parseInt(a.position) - parseInt(b.position)
    );
    const q3 = sorted.filter((r) => r.Q3);
    const q2 = sorted.filter((r) => r.Q2 && !r.Q3);
    const q1 = sorted.filter((r) => !r.Q2 && !r.Q3);

    function jSection(label: string, color: string, rows: any[], timeKey: string) {
      if (!rows.length) return "";
      const rowsHtml = rows.map((r) => {
        const isTop3 = parseInt(r.position) <= 3;
        return `
          <div class="grid grid-cols-[1.75rem_1.5rem_1fr_5.5rem] gap-x-2 px-3 py-2 items-center
                      transition-colors hover:bg-slate-50 dark:hover:bg-slate-700/50
                      ${isTop3 ? "bg-amber-50/60 dark:bg-amber-900/10" : ""}">
            <span class="text-xs font-mono text-gray-400 dark:text-slate-500 text-center">${r.position}</span>
            <span class="text-[10px] font-bold bg-slate-200 dark:bg-slate-600 rounded px-1 py-0.5 tabular-nums text-center">${r.Driver.permanentNumber ?? ""}</span>
            <span class="flex items-center gap-1.5 min-w-0">
              ${logoImg(r.Constructor?.constructorId ?? "", r.Constructor?.name ?? "")}
              <span class="truncate text-xs font-medium">${r.Driver.givenName[0]}. ${r.Driver.familyName}</span>
            </span>
            <span class="text-xs font-mono tabular-nums text-right text-gray-600 dark:text-slate-300">${(r as any)[timeKey] ?? "—"}</span>
          </div>`;
      }).join("");
      return `
        <div>
          <div class="flex items-center gap-2 mb-1 px-1">
            <span class="text-[10px] font-bold uppercase tracking-widest px-2 py-0.5 rounded-full ${color}">${label}</span>
          </div>
          <div class="rounded-lg border border-gray-200 dark:border-gray-700 overflow-hidden divide-y divide-gray-100 dark:divide-slate-700/50">
            ${rowsHtml}
          </div>
        </div>`;
    }

    if (q3.length) {
      return [
        jSection("Q3 — Top 10", "bg-red-100 text-red-700 dark:bg-red-900/40 dark:text-red-300", q3, "Q3"),
        jSection("Q2 — Out", "bg-orange-100 text-orange-700 dark:bg-orange-900/40 dark:text-orange-300", q2, "Q2"),
        jSection("Q1 — Out", "bg-slate-100 text-slate-600 dark:bg-slate-700 dark:text-slate-300", q1, "Q1"),
      ].join("");
    }
    return jSection(
      "Full Grid",
      "bg-slate-100 text-slate-600 dark:bg-slate-700 dark:text-slate-300",
      sorted,
      "Q1"
    );
  }

  function buildRaceModal(data: any[]): string {
    const sorted = [...data].sort(
      (a, b) => parseInt(a.position) - parseInt(b.position)
    );
    const fastestId = sorted.find((r) => r.FastestLap?.rank === "1")?.Driver?.driverId;

    const header = `
      <div class="grid grid-cols-[1.75rem_1.5rem_1fr_3rem_4.5rem_4rem] gap-x-2 px-3 py-1.5
                  bg-slate-100 dark:bg-slate-700/80 rounded-t-lg
                  border border-gray-200 dark:border-gray-700 border-b-0">
        <span class="text-[10px] font-semibold text-gray-400 dark:text-slate-500 text-center">#</span>
        <span class="text-[10px] font-semibold text-gray-400 dark:text-slate-500 text-center">No</span>
        <span class="text-[10px] font-semibold text-gray-400 dark:text-slate-500">Driver</span>
        <span class="text-[10px] font-semibold text-gray-400 dark:text-slate-500 text-center">Laps</span>
        <span class="text-[10px] font-semibold text-gray-400 dark:text-slate-500 text-right">Time / Status</span>
        <span class="text-[10px] font-semibold text-gray-400 dark:text-slate-500 text-right">Fastest</span>
      </div>`;

    const rows = sorted.map((r, i) => {
      const name = `${r.Driver.givenName[0]}. ${r.Driver.familyName}`;
      const cid = r.Constructor?.constructorId ?? "";
      const cname = r.Constructor?.name ?? "";
      const pos = r.positionText;
      const isDNF = ["R", "D", "E", "N"].includes(pos);
      const isFinished = r.status === "Finished" || r.status?.startsWith("+");
      const timeVal = r.Time?.time ?? (isFinished ? r.status : "");
      const statusVal = isDNF ? "DNF" : isFinished ? timeVal : r.status;
      const isFastest = r.Driver?.driverId === fastestId && fastestId;
      const fastestTime = r.FastestLap?.Time?.time ?? "";
      const rowBg = isDNF
        ? "bg-slate-50 dark:bg-slate-800/50 opacity-60"
        : i === 0
          ? "bg-amber-50/70 dark:bg-amber-900/10"
          : i % 2 === 0
            ? "bg-white dark:bg-slate-800"
            : "bg-slate-50 dark:bg-slate-700/30";

      return `
        <div class="grid grid-cols-[1.75rem_1.5rem_1fr_3rem_4.5rem_4rem] gap-x-2 px-3 py-2 items-center
                    transition-colors hover:bg-red-50 dark:hover:bg-slate-700/50 ${rowBg}">
          <span class="text-xs font-mono ${isDNF ? "text-gray-300 dark:text-slate-600" : "text-gray-400 dark:text-slate-500"} text-center">${isDNF ? "—" : pos}</span>
          <span class="text-[10px] font-bold bg-slate-200 dark:bg-slate-600 rounded px-1 py-0.5 tabular-nums text-center">${r.Driver.permanentNumber ?? ""}</span>
          <span class="flex items-center gap-1.5 min-w-0">
            ${logoImg(cid, cname)}
            <span class="truncate text-xs font-medium">${name}</span>
          </span>
          <span class="text-xs tabular-nums text-center text-gray-500 dark:text-slate-400">${r.laps}</span>
          <span class="text-xs font-mono tabular-nums text-right ${isDNF ? "text-red-500 dark:text-red-400 font-semibold" : "text-gray-600 dark:text-slate-300"}">${statusVal || "—"}</span>
          <span class="text-[10px] font-mono tabular-nums text-right ${isFastest ? "text-red-500 dark:text-red-400 font-bold" : "text-gray-400 dark:text-slate-500"}">${isFastest ? "⚡ " : ""}${fastestTime || "—"}</span>
        </div>`;
    }).join("");

    return `
      <div>
        ${header}
        <div class="rounded-b-lg border border-gray-200 dark:border-gray-700 border-t-0 overflow-hidden divide-y divide-gray-100 dark:divide-slate-700/50">
          ${rows}
        </div>
        <p class="text-[10px] text-gray-400 dark:text-slate-500 mt-2 text-right">⚡ = Fastest Lap</p>
      </div>`;
  }

  // ─── Results panel ────────────────────────────────────────────────────────
  async function showResults(
    session: { label: string; type: string },
    race: any
  ) {
    const panel = document.getElementById("f1-results-panel")!;
    const key = `${race.season}-${race.round}-${session.type}`;
    let data = allResults[key];

    // Client-side fallback for practice/sprint sessions missing from build-time data
    if ((!data || !data.length) && (session.type === "fp1" || session.type === "fp2" || session.type === "fp3" || session.type === "sprint_qualifying")) {
      let sessionKey = allSessionKeys[key];
      
      // If no session key from build time, try to fetch it dynamically
      if (!sessionKey) {
        panel.innerHTML = `<p class="text-xs text-gray-400 dark:text-slate-500 italic">Looking for session...</p>`;
        panel.classList.remove("hidden");
        
        try {
          // Map Jolpica country to OpenF1 country
          const countryMap: Record<string, string> = {
            Australia: "Australia", Bahrain: "Bahrain", "Saudi Arabia": "Saudi Arabia",
            Japan: "Japan", China: "China", USA: "United States", "United States": "United States",
            Italy: "Italy", Monaco: "Monaco", Canada: "Canada", Spain: "Spain",
            Austria: "Austria", UK: "United Kingdom", "United Kingdom": "United Kingdom",
            Hungary: "Hungary", Belgium: "Belgium", Netherlands: "Netherlands",
            Azerbaijan: "Azerbaijan", Singapore: "Singapore", Mexico: "Mexico", Brazil: "Brazil",
            "Las Vegas": "United States", Qatar: "Qatar", UAE: "United Arab Emirates", "Abu Dhabi": "United Arab Emirates",
          };
          const openF1Country = countryMap[race.Circuit?.Location?.country] || race.Circuit?.Location?.country || race.Circuit?.Location?.country;
          const sessionName = session.type === "fp1" ? "Practice 1" : session.type === "fp2" ? "Practice 2" : session.type === "fp3" ? "Practice 3" : "Sprint Qualifying";
          
          const skRes = await fetch(
            `https://api.openf1.org/v1/sessions?year=${race.season}&country_name=${encodeURIComponent(openF1Country)}&session_name=${encodeURIComponent(sessionName)}`
          );
          if (skRes.ok) {
            const skData = await skRes.json();
            if (skData?.[0]?.session_key) {
              sessionKey = skData[0].session_key;
              allSessionKeys[key] = sessionKey;
              setCachedSessionKey(key, sessionKey);
            }
          }
        } catch (e) {
          console.warn("Failed to fetch session key:", e);
        }
      }
      
      if (sessionKey) {
        panel.innerHTML = `<p class="text-xs text-gray-400 dark:text-slate-500 italic">Loading results…</p>`;
        panel.classList.remove("hidden");
        try {
          const [resRes, drvRes] = await Promise.all([
            fetch(`https://api.openf1.org/v1/session_result?session_key=${sessionKey}`),
            fetch(`https://api.openf1.org/v1/drivers?session_key=${sessionKey}`),
          ]);
          const rawResults = resRes.ok ? await resRes.json() : [];
          const drivers = drvRes.ok ? await drvRes.json() : [];
          const driverMap = new Map<number, any>();
          drivers.forEach((d: any) => driverMap.set(d.driver_number, d));
          data = rawResults
            .sort((a: any, b: any) => a.position - b.position)
            .map((r: any) => {
              const driver = driverMap.get(r.driver_number);
              const fullName = driver?.full_name ?? `#${r.driver_number}`;
              const parts = fullName.trim().split(" ");
              const name = parts.length >= 2
                ? `${parts[0][0]}. ${parts.slice(1).join(" ")}`
                : fullName;
              const gap = typeof r.gap_to_leader === "number" ? r.gap_to_leader : null;
              return {
                position: r.position,
                driverNumber: r.driver_number,
                name,
                teamName: driver?.team_name ?? "",
                lapTime: formatLapTime(r.duration),
                gapToLeader: gap != null && gap > 0 ? `+${gap.toFixed(3)}` : "—",
                laps: r.number_of_laps,
                dnf: r.dnf, dns: r.dns, dsq: r.dsq,
              };
            });
          allResults[key] = data; // cache in memory
          setCachedResult(key, data); // persist to sessionStorage
        } catch {
          data = [];
        }
      }
    }

    if (!data || !data.length) {
      panel.innerHTML = `<p class="text-xs text-gray-400 dark:text-slate-500 italic">Results not yet available.</p>`;
      panel.classList.remove("hidden");
      return;
    }

    const type = session.type;
    let html = "";

    if (type === "fp1" || type === "fp2" || type === "fp3") {
      html = renderOpenF1Podium(data);

    } else if (type === "sprint_qualifying") {
      html =
        renderOpenF1Podium(data) +
        fullGridBtn(`Full Sprint Qualifying Grid`, "sprint_qualifying");

    } else if (type === "qualifying") {
      html =
        renderJolpicaQualiPodium(data) +
        fullGridBtn("Full Qualifying Grid", "qualifying");

    } else if (type === "sprint") {
      html =
        renderJolpicaRacePodium(data) +
        fullGridBtn("Full Sprint Results", "sprint");

    } else if (type === "race") {
      html =
        renderJolpicaRacePodium(data) +
        fullGridBtn("Full Race Results", "race");
    }

    panel.innerHTML = html;
    panel.classList.remove("hidden");

    // Wire up modal button
    const btn = panel.querySelector<HTMLButtonElement>("button[data-modal]");
    if (btn) {
      btn.addEventListener("click", () => {
        const modalType = btn.dataset.modal!;
        const title =
          modalType === "qualifying"
            ? `${race.raceName} — Qualifying`
            : modalType === "sprint_qualifying"
              ? `${race.raceName} — Sprint Qualifying`
              : modalType === "sprint"
                ? `${race.raceName} — Sprint`
                : `${race.raceName} — Race Results`;

        const isOpenF1Quali = modalType === "sprint_qualifying";
        const isQuali =
          modalType === "qualifying" || modalType === "sprint_qualifying";

        const body = isQuali
          ? buildQualiModal(data, isOpenF1Quali)
          : buildRaceModal(data);

        openModal(title, body);
      });
    }
  }

  function hideResults() {
    const panel = document.getElementById("f1-results-panel")!;
    panel.classList.add("hidden");
    panel.innerHTML = "";
  }

  // ─── Modal controls ────────────────────────────────────────────────────────
  const backdrop = document.getElementById("f1-modal-backdrop") as HTMLDivElement;
  const modalTitle = document.getElementById("f1-modal-title")!;
  const modalBody = document.getElementById("f1-modal-body")!;

  function openModal(title: string, body: string) {
    modalTitle.textContent = title;
    modalBody.innerHTML = body;
    backdrop.classList.remove("hidden");
    backdrop.classList.add("flex");
    document.body.style.overflow = "hidden";
  }
  function closeModal() {
    backdrop.classList.add("hidden");
    backdrop.classList.remove("flex");
    document.body.style.overflow = "";
  }

  document.getElementById("f1-modal-close")!.addEventListener("click", closeModal);
  backdrop.addEventListener("click", (e) => { if (e.target === backdrop) closeModal(); });
  document.addEventListener("keydown", (e) => { if (e.key === "Escape") closeModal(); });

  // ─── Countdown ────────────────────────────────────────────────────────────
  function startCountdown(
    targetDate: Date,
    session: { label: string; type: string },
    race: any
  ) {
    if (countdownInterval) clearInterval(countdownInterval);

    function tick() {
      const diff = targetDate.getTime() - Date.now();
      if (diff <= 0) {
        ["days", "hours", "mins", "secs"].forEach(
          (id) => (document.getElementById(`cd-${id}`)!.textContent = "00")
        );
        clearInterval(countdownInterval!);
        void showResults(session, race);
        return;
      }
      document.getElementById("cd-days")!.textContent = pad(Math.floor(diff / 86400000));
      document.getElementById("cd-hours")!.textContent = pad(Math.floor((diff % 86400000) / 3600000));
      document.getElementById("cd-mins")!.textContent = pad(Math.floor((diff % 3600000) / 60000));
      document.getElementById("cd-secs")!.textContent = pad(Math.floor((diff % 60000) / 1000));
    }
    tick();
    countdownInterval = setInterval(tick, 1000);
  }

  // ─── Session tabs ─────────────────────────────────────────────────────────
  function renderSessionTabs(race: any) {
    const container = document.getElementById("f1-session-tabs")!;
    container.innerHTML = "";
    sessions.forEach((session, i) => {
      const isPast = session.date.getTime() < Date.now();
      const isActive = i === activeSessionIndex;
      const hasData =
        isPast &&
        (allResults[`${race.season}-${race.round}-${session.type}`]?.length ?? 0) > 0;

      const btn = document.createElement("button");
      btn.textContent = session.label;
      btn.className = [
        "relative px-2 py-1 text-xs rounded-md font-medium transition-colors",
        isActive
          ? "bg-red-600 text-white"
          : "bg-gray-200 dark:bg-slate-700 text-gray-700 dark:text-slate-300 hover:bg-gray-300 dark:hover:bg-slate-600",
      ].join(" ");

      if (hasData && !isActive) {
        const dot = document.createElement("span");
        dot.className =
          "absolute -top-0.5 -right-0.5 w-1.5 h-1.5 rounded-full bg-red-400";
        btn.appendChild(dot);
      }

      btn.addEventListener("click", () => {
        activeSessionIndex = i;
        renderSessionTabs(race);
        updateSessionDisplay(race);
      });
      container.appendChild(btn);
    });
  }

  function updateSessionDisplay(race: any) {
    const session = sessions[activeSessionIndex];
    if (!session) return;

    document.getElementById("f1-session-label")!.textContent = session.label;
    document.getElementById("f1-session-datetime")!.textContent =
      formatLocalDateTime(session.date);

    const isPast = session.date.getTime() < Date.now();
    if (isPast) {
      ["days", "hours", "mins", "secs"].forEach(
        (id) => (document.getElementById(`cd-${id}`)!.textContent = "00")
      );
      if (countdownInterval) clearInterval(countdownInterval);
      void showResults(session, race);
    } else {
      hideResults();
      startCountdown(session.date, session, race);
    }
  }

  // ─── Dots ─────────────────────────────────────────────────────────────────
  function renderDots() {
    const container = document.getElementById("f1-dots")!;
    container.innerHTML = "";
    allRaces.forEach((r, i) => {
      const ms = new Date(`${r.date}T${r.time ?? "00:00:00"}`).getTime();
      const dot = document.createElement("button");
      dot.setAttribute("aria-label", `Round ${i + 1}: ${r.raceName}`);
      dot.className = [
        "w-2 h-2 rounded-full transition-all duration-200 focus:outline-none",
        i === currentRaceIndex
          ? "bg-red-500 scale-125"
          : i === nextRaceIndex
            ? "bg-orange-400"
            : ms < now
              ? "bg-slate-400 dark:bg-slate-500"
              : "bg-slate-300 dark:bg-slate-600",
      ].join(" ");
      dot.addEventListener("click", () => { currentRaceIndex = i; renderRace(); });
      container.appendChild(dot);
    });
  }

  // ─── Main render ──────────────────────────────────────────────────────────
  function renderRace() {
    const race = allRaces[currentRaceIndex];
    if (!race) return;

    const raceMs = new Date(`${race.date}T${race.time ?? "00:00:00"}`).getTime();
    const isNext = currentRaceIndex === nextRaceIndex;
    const isPast = raceMs < now;
    const LABELS = JSON.parse(
      (document.getElementById("f1-widget") as HTMLElement).dataset.labels ?? "{}"
    );

    const badge = document.getElementById("f1-badge")!;
    if (isNext) {
      badge.textContent = LABELS.nextRace;
      badge.className = "text-xs font-bold px-2 py-0.5 rounded-full bg-red-600 text-white uppercase tracking-wide";
    } else if (isPast) {
      badge.textContent = LABELS.pastRace;
      badge.className = "text-xs font-bold px-2 py-0.5 rounded-full bg-slate-500 text-white uppercase tracking-wide";
    } else {
      badge.textContent = LABELS.upcoming;
      badge.className = "text-xs font-bold px-2 py-0.5 rounded-full bg-orange-500 text-white uppercase tracking-wide";
    }

    document.getElementById("f1-round")!.textContent =
      `${race.season} · ${LABELS.round} ${race.round}`;
    document.getElementById("f1-race-name")!.textContent = race.raceName;
    document.getElementById("f1-circuit-name")!.textContent =
      `${race.Circuit.circuitName}, ${race.Circuit.Location.locality}`;
    document.getElementById("f1-flag")!.textContent =
      COUNTRY_FLAGS[race.Circuit.Location.country] ?? "🏁";

    const imgEl = document.getElementById("f1-circuit-img") as HTMLImageElement;
    imgEl.onload = null;
    imgEl.onerror = null;
    imgEl.classList.add("hidden");
    const imgSrc = CIRCUIT_IMAGES[race.Circuit.circuitId];
    if (imgSrc) {
      imgEl.onload = () => imgEl.classList.remove("hidden");
      imgEl.onerror = () => imgEl.classList.add("hidden");
      imgEl.src = imgSrc;
      imgEl.alt = `${race.raceName} circuit map`;
    }

    sessions = buildSessions(race);
    const upcomingIdx = sessions.findIndex((s) => s.date.getTime() > now);
    activeSessionIndex = upcomingIdx >= 0 ? upcomingIdx : sessions.length - 1;
    renderSessionTabs(race);
    updateSessionDisplay(race);

    (document.getElementById("f1-prev") as HTMLButtonElement).disabled =
      currentRaceIndex === 0;
    (document.getElementById("f1-next") as HTMLButtonElement).disabled =
      currentRaceIndex === allRaces.length - 1;

    renderDots();
  }

  // ─── Controls ─────────────────────────────────────────────────────────────
  document.getElementById("f1-prev")!.addEventListener("click", () => {
    if (currentRaceIndex > 0) { currentRaceIndex--; renderRace(); }
  });
  document.getElementById("f1-next")!.addEventListener("click", () => {
    if (currentRaceIndex < allRaces.length - 1) { currentRaceIndex++; renderRace(); }
  });

  const activeTabCls = "bg-red-600 text-white";
  const inactiveTabCls =
    "bg-gray-200 dark:bg-slate-700 text-gray-700 dark:text-slate-300 hover:bg-gray-300 dark:hover:bg-slate-600";
  const tabBase = "px-3 py-1 text-xs font-semibold rounded-full transition-colors";

  document.getElementById("tab-drivers")!.addEventListener("click", () => {
    document.getElementById("standings-drivers")!.classList.remove("hidden");
    document.getElementById("standings-constructors")!.classList.add("hidden");
    document.getElementById("tab-drivers")!.className = `${tabBase} ${activeTabCls}`;
    document.getElementById("tab-constructors")!.className = `${tabBase} ${inactiveTabCls}`;
  });
  document.getElementById("tab-constructors")!.addEventListener("click", () => {
    document.getElementById("standings-constructors")!.classList.remove("hidden");
    document.getElementById("standings-drivers")!.classList.add("hidden");
    document.getElementById("tab-constructors")!.className = `${tabBase} ${activeTabCls}`;
    document.getElementById("tab-drivers")!.className = `${tabBase} ${inactiveTabCls}`;
  });

  renderRace();
</script>