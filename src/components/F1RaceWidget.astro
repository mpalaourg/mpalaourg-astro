---
import { getSeasonRaces, getDriverStandings, getConstructorStandings } from "../utils/f1";
const [races, driverStandings, constructorStandings] = await Promise.all([
  getSeasonRaces(),
  getDriverStandings(),
  getConstructorStandings(),
]);

// Enrich constructors with their drivers' breakdown
const totalConstructorPts = constructorStandings.reduce(
  (s, c) => s + parseFloat(c.points), 0
);
const enrichedConstructors = constructorStandings.map((c) => {
  const drivers = driverStandings
    .filter((d) => d.Constructors.some((co) => co.name === c.Constructor.name))
    .map((d) => ({
      name: `${d.Driver.givenName[0]}. ${d.Driver.familyName}`,
      points: d.points,
      pct: totalConstructorPts > 0
        ? ((parseFloat(d.points) / parseFloat(c.points)) * 100).toFixed(0)
        : "0",
    }));
  return { ...c, drivers };
});
const BASE = import.meta.env.BASE_URL.replace(/\/$/, "");
const TEAM_LOGOS: Record<string, string> = {
    mercedes: `${BASE}/formula/team-logos/mercedes.svg`,
    ferrari: `${BASE}/formula/team-logos/ferrari.svg`,
    red_bull: `${BASE}/formula/team-logos/red_bull.png`,
    mclaren: `${BASE}/formula/team-logos/mclaren.png`,
    alpine: `${BASE}/formula/team-logos/alpine.svg`,
    aston_martin: `${BASE}/formula/team-logos/aston_martin.svg`,
    williams: `${BASE}/formula/team-logos/williams.svg`,
    haas: `${BASE}/formula/team-logos/haas.svg`,
    rb: `${BASE}/formula/team-logos/rb.svg`,
    audi: `${BASE}/formula/team-logos/audi.svg`,
    cadillac: `${BASE}/formula/team-logos/cadillac.svg`,
};
interface Props {
  lang?: "en" | "el";
}
const { lang = "en" } = Astro.props;

const t = {
  en: {
    nextRace: "Next Race",
    pastRace: "Past Race",
    upcoming: "Upcoming",
    round: "Round",
    drivers: "Drivers",
    constructors: "Constructors",
    noRaceData: "No race data available.",
    seasonNotStarted: "Season hasn't started yet",
    driverStandingsEmpty: "Driver standings will appear after Round 1",
    constructorStandingsEmpty: "Constructor standings will appear after Round 1",
    days: "days", hrs: "hrs", min: "min", sec: "sec",
    prev: "Prev", next: "Next",
    driver: "Driver",
    constructor: "Constructor",
    number: "No",
    points: "Points",
    wins: "Wins",
    pts: "pts",
  },
  el: {
    nextRace: "Επόμενος Αγώνας",
    pastRace: "Προηγούμενος Αγώνας",
    upcoming: "Προσεχής",
    round: "Γύρος",
    drivers: "Οδηγοί",
    constructors: "Κατασκευαστές",
    noRaceData: "Δεν υπάρχουν διαθέσιμα δεδομένα αγώνα.",
    seasonNotStarted: "Η σεζόν δεν έχει ξεκινήσει ακόμα",
    driverStandingsEmpty: "Η κατάταξη οδηγών θα εμφανιστεί μετά τον 1ο γύρο",
    constructorStandingsEmpty: "Η κατάταξη κατασκευαστών θα εμφανιστεί μετά τον 1ο γύρο",
    days: "μέρες", hrs: "ώρες", min: "λεπτά", sec: "δευτ",
    prev: "Προηγ", next: "Επόμενο",
    driver: "Οδηγός",
    constructor: "Κατασκευαστής",
    number: "Αρ",
    points: "Βαθμοί",
    wins: "Νίκες",
    pts: "βαθ",
  },
} as const;

const T = t[lang];
---

{races.length > 0 ? (
<div
  id="f1-widget"
  data-labels={JSON.stringify({
    nextRace: T.nextRace,
    pastRace: T.pastRace,
    upcoming: T.upcoming,
    round: T.round,
  })}
  class="rounded-xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-slate-800 p-5 shadow-sm"
>
  <script
    id="f1-all-races"
    type="application/json"
    set:html={JSON.stringify(races)}
  />

  <div id="f1-content">
    <!-- Header -->
    <div class="flex items-start justify-between gap-4 mb-4">
      <div class="flex-1 min-w-0">
        <div class="flex items-center gap-2 mb-1 flex-wrap">
          <span
            id="f1-badge"
            class="text-xs font-bold px-2 py-0.5 rounded-full bg-red-600 text-white uppercase tracking-wide"
          >Next Race</span>
          <span
            id="f1-round"
            class="text-xs text-gray-500 dark:text-slate-400"
          ></span>
        </div>
        <h3 id="f1-race-name" class="text-xl font-bold"></h3>
        <p id="f1-circuit-name" class="text-sm text-gray-500 dark:text-slate-400"></p>
      </div>
      <div id="f1-flag" class="text-4xl shrink-0"></div>
    </div>

    <!-- Sessions + circuit image -->
    <div class="flex flex-col md:flex-row gap-4 mb-4">
      <!-- Left: sessions -->
      <div class="flex-1 min-w-0">
        <div class="flex flex-wrap gap-1 mb-3" id="f1-session-tabs"></div>
        <div class="rounded-lg bg-slate-100 dark:bg-slate-700/50 p-3">
          <p
            id="f1-session-label"
            class="text-xs font-semibold uppercase tracking-wide text-gray-500 dark:text-slate-400 mb-1"
          ></p>
          <p
            id="f1-session-datetime"
            class="text-xs text-gray-500 dark:text-slate-400 mb-2"
          ></p>
          <div class="flex gap-3">
            <div class="text-center">
              <div id="cd-days" class="text-2xl font-bold font-mono tabular-nums">--</div>
              <div class="text-xs text-gray-500 dark:text-slate-400">{T.days}</div>
            </div>
            <div class="text-xl font-bold self-start mt-1">:</div>
            <div class="text-center">
              <div id="cd-hours" class="text-2xl font-bold font-mono tabular-nums">--</div>
              <div class="text-xs text-gray-500 dark:text-slate-400">{T.hrs}</div>
            </div>
            <div class="text-xl font-bold self-start mt-1">:</div>
            <div class="text-center">
              <div id="cd-mins" class="text-2xl font-bold font-mono tabular-nums">--</div>
              <div class="text-xs text-gray-500 dark:text-slate-400">{T.min}</div>
            </div>
            <div class="text-xl font-bold self-start mt-1">:</div>
            <div class="text-center">
              <div id="cd-secs" class="text-2xl font-bold font-mono tabular-nums">--</div>
              <div class="text-xs text-gray-500 dark:text-slate-400">{T.sec}</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Right: circuit image -->
      <div class="md:w-48 shrink-0 flex items-center justify-center rounded-xl bg-slate-100 dark:bg-slate-700/60 p-3">
        <img
            id="f1-circuit-img"
            src=""
            alt="Circuit map"
            class="max-h-40 max-w-full object-contain hidden"
        />
      </div>
    </div>

    <!-- Navigation -->
    <div class="flex items-center justify-between mt-2 gap-2">
      <button
        id="f1-prev"
        aria-label="Previous race"
        class="flex items-center gap-1 px-3 py-1.5 rounded-lg text-sm font-medium
               bg-gray-100 dark:bg-slate-700 text-gray-700 dark:text-slate-300
               hover:bg-gray-200 dark:hover:bg-slate-600 disabled:opacity-30
               disabled:cursor-not-allowed transition-colors shrink-0"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
        </svg>
        {T.prev}
      </button>

      <div id="f1-dots" class="flex gap-1 flex-wrap justify-center flex-1"></div>

      <button
        id="f1-next"
        aria-label="Next race"
        class="flex items-center gap-1 px-3 py-1.5 rounded-lg text-sm font-medium
               bg-gray-100 dark:bg-slate-700 text-gray-700 dark:text-slate-300
               hover:bg-gray-200 dark:hover:bg-slate-600 disabled:opacity-30
               disabled:cursor-not-allowed transition-colors shrink-0"
      >
        {T.next}
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
      </button>
    </div>
  </div>
    <!-- Standings -->
    <div class="mt-5 border-t border-gray-200 dark:border-gray-700 pt-4">
    <!-- Tab switcher -->
    <div class="flex gap-2 mb-3">
        <button
        id="tab-drivers"
        class="px-3 py-1 text-xs font-semibold rounded-full bg-red-600 text-white transition-colors"
        >{T.drivers}</button>
        <button
        id="tab-constructors"
        class="px-3 py-1 text-xs font-semibold rounded-full bg-gray-200 dark:bg-slate-700 text-gray-700 dark:text-slate-300 hover:bg-gray-300 dark:hover:bg-slate-600 transition-colors"
        >{T.constructors}</button>
    </div>

    <!-- Driver standings -->
    <div id="standings-drivers">
    {driverStandings.length > 0 ? (
        <div class="overflow-hidden rounded-lg border border-gray-200 dark:border-gray-700">
        <!-- Header -->
        <div class="grid grid-cols-[2rem_2rem_1fr_3.5rem_2.5rem] gap-x-2 px-3 py-1.5
                    bg-slate-100 dark:bg-slate-700/80 border-b border-gray-200 dark:border-gray-700">
            <span class="text-xs font-semibold text-gray-400 dark:text-slate-500 text-center">#</span>
            <span class="text-xs font-semibold text-gray-400 dark:text-slate-500 text-center">{T.number}</span>
            <span class="text-xs font-semibold text-gray-400 dark:text-slate-500">{T.driver}</span>
            <span class="text-xs font-semibold text-gray-400 dark:text-slate-500 text-right">{T.points}</span>
            <span class="text-xs font-semibold text-gray-400 dark:text-slate-500 text-right">{T.wins}</span>
        </div>
        <!-- Rows -->
        <div class="max-h-64 overflow-y-auto divide-y divide-gray-100 dark:divide-slate-700/50">
            {driverStandings.map((d, i) => {
            const constructorId = d.Constructors[0]?.constructorId ?? "";
            const logoSrc = TEAM_LOGOS[constructorId];
            return (
                <div class={[
                "grid grid-cols-[2rem_2rem_1fr_3.5rem_2.5rem] gap-x-2 px-3 py-2 items-center",
                "transition-colors hover:bg-red-50 dark:hover:bg-slate-700/40",
            	i % 2 === 0 ? "bg-white dark:bg-slate-800" : "bg-slate-50 dark:bg-slate-700/40",
                ].join(" ")}>
                <span class="text-xs text-gray-400 dark:text-slate-500 font-mono text-center">{d.position}</span>
                <span class="text-xs font-bold text-center bg-slate-200 dark:bg-slate-700 rounded px-1 py-0.5 tabular-nums">{d.Driver.permanentNumber}</span>
                <span class="flex items-center gap-2 min-w-0">
                    {logoSrc ? (
                    <img src={logoSrc} alt={d.Constructors[0]?.name} class="h-4 w-6 object-contain shrink-0" />
                    ) : (
                    <span class="h-3 w-3 rounded-full shrink-0 bg-slate-400" />
                    )}
                    <span class="truncate text-sm font-medium">
                    {d.Driver.givenName[0]}. {d.Driver.familyName}
                    </span>
                </span>
                <span class="text-sm font-bold tabular-nums text-right">{d.points}</span>
                <span class="text-xs text-gray-400 dark:text-slate-500 text-right tabular-nums">{d.wins}</span>
                </div>
            );
            })}
        </div>
        </div>
    ) : (
        <div class="flex flex-col items-center justify-center py-8 text-center gap-2">
        <span class="text-2xl">🏎️</span>
        <p class="text-sm font-medium text-gray-500 dark:text-slate-400">{T.seasonNotStarted}</p>
        <p class="text-xs text-gray-400 dark:text-slate-500">{T.driverStandingsEmpty}</p>
        </div>
    )}
    </div>

    <!-- Constructor standings -->
    <div id="standings-constructors" class="hidden">
    {enrichedConstructors.length > 0 ? (
        <div class="overflow-hidden rounded-lg border border-gray-200 dark:border-gray-700">
        <!-- Header -->
        <div class="grid grid-cols-[2rem_1fr_3.5rem_2.5rem] gap-x-2 px-3 py-1.5
                    bg-slate-100 dark:bg-slate-700/80 border-b border-gray-200 dark:border-gray-700">
            <span class="text-xs font-semibold text-gray-400 dark:text-slate-500 text-center">#</span>
            <span class="text-xs font-semibold text-gray-400 dark:text-slate-500">{T.constructor}</span>
            <span class="text-xs font-semibold text-gray-400 dark:text-slate-500 text-right">{T.points}</span>
            <span class="text-xs font-semibold text-gray-400 dark:text-slate-500 text-right">{T.wins}</span>
        </div>
        <!-- Rows -->
        <div class="max-h-64 overflow-y-auto divide-y divide-gray-100 dark:divide-slate-700/50">
            {enrichedConstructors.map((c, i) => {
            const logoSrc = TEAM_LOGOS[c.Constructor.constructorId];
            return (
                <div class={[
                i % 2 === 0 ? "bg-white dark:bg-slate-800" : "bg-slate-50 dark:bg-slate-700/40",
                ].join(" ")}>
                <!-- Constructor row -->
                <div class="grid grid-cols-[2rem_1fr_3.5rem_2.5rem] gap-x-2 px-3 py-2 items-center
                            transition-colors hover:bg-red-50 dark:hover:bg-slate-700/40">
                    <span class="text-xs text-gray-400 dark:text-slate-500 font-mono text-center">{c.position}</span>
                    <span class="flex items-center gap-2 min-w-0">
                    {logoSrc ? (
                        <img src={logoSrc} alt={c.Constructor.name} class="h-4 w-6 object-contain shrink-0" />
                    ) : (
                        <span class="h-3 w-3 rounded-full shrink-0 bg-slate-400" />
                    )}
                    <span class="truncate text-sm font-semibold">{c.Constructor.name}</span>
                    </span>
                    <span class="text-sm font-bold tabular-nums text-right">{c.points}</span>
                    <span class="text-xs text-gray-400 dark:text-slate-500 text-right tabular-nums">{c.wins}</span>
                </div>
                <!-- Driver breakdown sub-rows -->
                {c.drivers && c.drivers.length > 0 && (
                    <div class="pb-1.5 px-3 ml-8 space-y-0.5">
                    {c.drivers.map((drv) => (
                        <div class="flex items-center gap-2 text-xs text-gray-500 dark:text-slate-400">
                        <span class="flex-1 truncate">{drv.name}</span>
                        <span class="tabular-nums font-medium">{drv.points} {T.pts}</span>
                        <div class="w-20 flex items-center gap-1">
                            <div class="flex-1 h-1 rounded-full bg-slate-200 dark:bg-slate-600 overflow-hidden">
                            <div
                                class="h-full rounded-full bg-red-400 dark:bg-red-500"
                                style={`width: ${drv.pct}%`}
                            />
                            </div>
                            <span class="w-7 text-right tabular-nums text-gray-400 dark:text-slate-500">{drv.pct}%</span>
                        </div>
                        </div>
                    ))}
                    </div>
                )}
                </div>
            );
            })}
        </div>
        </div>
    ) : (
        <div class="flex flex-col items-center justify-center py-8 text-center gap-2">
        <span class="text-2xl">🏗️</span>
        <p class="text-sm font-medium text-gray-500 dark:text-slate-400">{T.seasonNotStarted}</p>
        <p class="text-xs text-gray-400 dark:text-slate-500">{T.constructorStandingsEmpty}</p>
        </div>
    )}
    </div>
    
    </div>
</div>
) : (
  <div class="rounded-xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-slate-800 p-5 text-sm text-gray-500 dark:text-slate-400">
    {T.noRaceData}
  </div>
)}

<script>
  const COUNTRY_FLAGS: Record<string, string> = {
    Australia: "🇦🇺", Bahrain: "🇧🇭", "Saudi Arabia": "🇸🇦",
    Japan: "🇯🇵", China: "🇨🇳", USA: "🇺🇸", "United States": "🇺🇸",
    Italy: "🇮🇹", Monaco: "🇲🇨", Canada: "🇨🇦", Spain: "🇪🇸",
    Austria: "🇦🇹", UK: "🇬🇧", "United Kingdom": "🇬🇧",
    Hungary: "🇭🇺", Belgium: "🇧🇪", Netherlands: "🇳🇱",
    Azerbaijan: "🇦🇿", Singapore: "🇸🇬", Mexico: "🇲🇽",
    Brazil: "🇧🇷", "Las Vegas": "🇺🇸", Qatar: "🇶🇦",
    UAE: "🇦🇪", "Abu Dhabi": "🇦🇪",
  };

  const BASE = import.meta.env.BASE_URL.replace(/\/$/, "");
  const CIRCUIT_IMAGES: Record<string, string> = {
    albert_park: `${BASE}/formula/circuit-images/albert_park.svg`,
    bahrain: `${BASE}/formula/circuit-images/bahrain.svg`,
    jeddah: `${BASE}/formula/circuit-images/jeddah.svg`,
    suzuka: `${BASE}/formula/circuit-images/suzuka.svg`,
    shanghai: `${BASE}/formula/circuit-images/shanghai.svg`,
    miami: `${BASE}/formula/circuit-images/miami.svg`,
    imola: `${BASE}/formula/circuit-images/imola.svg`,
    monaco: `${BASE}/formula/circuit-images/monaco.svg`,
    villeneuve: `${BASE}/formula/circuit-images/villeneuve.svg`,
    catalunya: `${BASE}/formula/circuit-images/catalunya.svg`,
    red_bull_ring: `${BASE}/formula/circuit-images/red_bull_ring.svg`,
    silverstone: `${BASE}/formula/circuit-images/silverstone.png`,
    hungaroring: `${BASE}/formula/circuit-images/hungaroring.svg`,
    spa: `${BASE}/formula/circuit-images/spa.svg`,
    zandvoort: `${BASE}/formula/circuit-images/zandvoort.png`,
    monza: `${BASE}/formula/circuit-images/monza.svg`,
    baku: `${BASE}/formula/circuit-images/baku.svg`,
    marina_bay: `${BASE}/formula/circuit-images/marina_bay.svg`,
    americas: `${BASE}/formula/circuit-images/americas.svg`,
    rodriguez: `${BASE}/formula/circuit-images/rodriguez.svg`,
    interlagos: `${BASE}/formula/circuit-images/interlagos.svg`,
    vegas: `${BASE}/formula/circuit-images/vegas.svg`,
    losail: `${BASE}/formula/circuit-images/losail.svg`,
    yas_marina: `${BASE}/formula/circuit-images/yas_marina.png`,
    madring: `${BASE}/formula/circuit-images/madrid.svg`,
   };

  // ─── State ────────────────────────────────────────────────────────────────
  const dataEl = document.getElementById("f1-all-races");
  if (!dataEl) throw new Error("No race data element");

  const allRaces: any[] = JSON.parse(dataEl.textContent ?? "[]");
  const now = Date.now();

  const nextRaceIndex = (() => {
    const idx = allRaces.findIndex((r) => {
      const d = new Date(`${r.date}T${r.time ?? "00:00:00"}`);
      return d.getTime() > now;
    });
    return idx >= 0 ? idx : allRaces.length - 1;
  })();

  let currentRaceIndex = nextRaceIndex;
  let sessions: { label: string; date: Date }[] = [];
  let activeSessionIndex = 0;
  let countdownInterval: ReturnType<typeof setInterval> | null = null;

  // ─── Helpers ──────────────────────────────────────────────────────────────
  function pad(n: number) {
    return String(n).padStart(2, "0");
  }

  function formatLocalDateTime(date: Date): string {
    // Render in the user's local timezone (browser does this automatically)
    const base = date.toLocaleString(undefined, {
      weekday: "short",
      day: "numeric",
      month: "short",
      hour: "2-digit",
      minute: "2-digit",
    });

    // Append explicit UTC offset, e.g. "(UTC+2)" or "(UTC+5:30)"
    const offsetMins = -date.getTimezoneOffset();
    const sign = offsetMins >= 0 ? "+" : "-";
    const abs = Math.abs(offsetMins);
    const hh = Math.floor(abs / 60);
    const mm = abs % 60;
    const utcLabel = mm === 0
      ? `UTC${sign}${hh}`
      : `UTC${sign}${String(hh).padStart(2, "0")}:${String(mm).padStart(2, "0")}`;

    return `${base} (${utcLabel})`;
  }

  function buildSessions(race: any): { label: string; date: Date }[] {
    const raw = [
      { label: "FP1", obj: race.FirstPractice },
      { label: "FP2", obj: race.SecondPractice },
      { label: "FP3", obj: race.ThirdPractice },
      { label: "Sprint Quali", obj: race.SprintQualifying },
      { label: "Sprint", obj: race.Sprint },
      { label: "Qualifying", obj: race.Qualifying },
      { label: "Race", obj: { date: race.date, time: race.time } },
    ];
    return raw
      .filter((s) => s.obj?.date)
      .map((s) => ({
        label: s.label,
        date: s.obj.time
          ? new Date(`${s.obj.date}T${s.obj.time}`)
          : new Date(`${s.obj.date}T00:00:00`),
      }))
      .sort((a, b) => a.date.getTime() - b.date.getTime());
  }

  function startCountdown(targetDate: Date) {
    if (countdownInterval) clearInterval(countdownInterval);

    function tick() {
      const diff = targetDate.getTime() - Date.now();
      if (diff <= 0) {
        ["days", "hours", "mins", "secs"].forEach(
          (id) => (document.getElementById(`cd-${id}`)!.textContent = "00")
        );
        clearInterval(countdownInterval!);
        return;
      }
      document.getElementById("cd-days")!.textContent = pad(Math.floor(diff / 86400000));
      document.getElementById("cd-hours")!.textContent = pad(Math.floor((diff % 86400000) / 3600000));
      document.getElementById("cd-mins")!.textContent = pad(Math.floor((diff % 3600000) / 60000));
      document.getElementById("cd-secs")!.textContent = pad(Math.floor((diff % 60000) / 1000));
    }
    tick();
    countdownInterval = setInterval(tick, 1000);
  }

  // ─── Render helpers ───────────────────────────────────────────────────────
  function renderSessionTabs() {
    const container = document.getElementById("f1-session-tabs")!;
    container.innerHTML = "";
    sessions.forEach((session, i) => {
      const btn = document.createElement("button");
      btn.textContent = session.label;
      btn.className = [
        "px-2 py-1 text-xs rounded-md font-medium transition-colors",
        i === activeSessionIndex
          ? "bg-red-600 text-white"
          : "bg-gray-200 dark:bg-slate-700 text-gray-700 dark:text-slate-300 hover:bg-gray-300 dark:hover:bg-slate-600",
      ].join(" ");
      btn.addEventListener("click", () => {
        activeSessionIndex = i;
        renderSessionTabs();
        updateCountdownDisplay();
      });
      container.appendChild(btn);
    });
  }

  function updateCountdownDisplay() {
    const session = sessions[activeSessionIndex];
    if (!session) return;
    document.getElementById("f1-session-label")!.textContent = session.label;
    // Uses browser local timezone automatically
    document.getElementById("f1-session-datetime")!.textContent =
      formatLocalDateTime(session.date);
    startCountdown(session.date);
  }

  function renderDots() {
    const container = document.getElementById("f1-dots")!;
    container.innerHTML = "";
    allRaces.forEach((r, i) => {
      const raceMs = new Date(
        `${r.date}T${r.time ?? "00:00:00"}`
      ).getTime();
      const isPast = raceMs < now;
      const isCurrent = i === currentRaceIndex;
      const isNext = i === nextRaceIndex;

      const dot = document.createElement("button");
      dot.setAttribute("aria-label", `Round ${i + 1}: ${r.raceName}`);
      dot.className = [
        "w-2 h-2 rounded-full transition-all duration-200 focus:outline-none",
        isCurrent
          ? "bg-red-500 scale-125"
          : isNext
          ? "bg-orange-400"
          : isPast
          ? "bg-slate-400 dark:bg-slate-500"
          : "bg-slate-300 dark:bg-slate-600",
      ].join(" ");
      dot.addEventListener("click", () => {
        currentRaceIndex = i;
        renderRace();
      });
      container.appendChild(dot);
    });
  }

  function renderRace() {
    const race = allRaces[currentRaceIndex];
    if (!race) return;

    // Badge
    const badge = document.getElementById("f1-badge")!;
    const raceMs = new Date(`${race.date}T${race.time ?? "00:00:00"}`).getTime();
    const isNext = currentRaceIndex === nextRaceIndex;
    const isPast = raceMs < now;
    const widget = document.getElementById("f1-widget")!;
    const LABELS = JSON.parse(widget.dataset.labels ?? "{}");

    if (isNext) {
      badge.textContent = LABELS.nextRace;
      badge.className =
        "text-xs font-bold px-2 py-0.5 rounded-full bg-red-600 text-white uppercase tracking-wide";
    } else if (isPast) {
      badge.textContent = LABELS.pastRace;
      badge.className =
        "text-xs font-bold px-2 py-0.5 rounded-full bg-slate-500 text-white uppercase tracking-wide";
    } else {
      badge.textContent = LABELS.upcoming;
      badge.className =
        "text-xs font-bold px-2 py-0.5 rounded-full bg-orange-500 text-white uppercase tracking-wide";
    }

    document.getElementById("f1-round")!.textContent =
      `${race.season} · ${LABELS.round} ${race.round}`;
    document.getElementById("f1-race-name")!.textContent = race.raceName;
    document.getElementById("f1-circuit-name")!.textContent =
      `${race.Circuit.circuitName}, ${race.Circuit.Location.locality}`;
    document.getElementById("f1-flag")!.textContent =
      COUNTRY_FLAGS[race.Circuit.Location.country] ?? "🏁";

    // Circuit image — properly reset handlers to avoid stale closures
    const imgEl = document.getElementById("f1-circuit-img") as HTMLImageElement;
    imgEl.onload = null;
    imgEl.onerror = null;
    imgEl.classList.add("hidden");
    const imgSrc = CIRCUIT_IMAGES[race.Circuit.circuitId];
    if (imgSrc) {
      imgEl.onload = () => imgEl.classList.remove("hidden");
      imgEl.onerror = () => imgEl.classList.add("hidden");
      imgEl.src = imgSrc;
      imgEl.alt = `${race.raceName} circuit map`;
    }

    // Sessions
    sessions = buildSessions(race);
    const upcomingIdx = sessions.findIndex((s) => s.date.getTime() > now);
    activeSessionIndex = upcomingIdx >= 0 ? upcomingIdx : sessions.length - 1;
    renderSessionTabs();
    updateCountdownDisplay();

    // Arrows
    (document.getElementById("f1-prev") as HTMLButtonElement).disabled =
      currentRaceIndex === 0;
    (document.getElementById("f1-next") as HTMLButtonElement).disabled =
      currentRaceIndex === allRaces.length - 1;

    renderDots();
  }

  // ─── Controls ─────────────────────────────────────────────────────────────
  document.getElementById("f1-prev")!.addEventListener("click", () => {
    if (currentRaceIndex > 0) { currentRaceIndex--; renderRace(); }
  });
  document.getElementById("f1-next")!.addEventListener("click", () => {
    if (currentRaceIndex < allRaces.length - 1) { currentRaceIndex++; renderRace(); }
  });

  // ─── Standings tabs ────────────────────────────────────────────────────────
    const tabDrivers = document.getElementById("tab-drivers")!;
    const tabConstructors = document.getElementById("tab-constructors")!;
    const panelDrivers = document.getElementById("standings-drivers")!;
    const panelConstructors = document.getElementById("standings-constructors")!;

    const activeTab =
    "bg-red-600 text-white";
    const inactiveTab =
    "bg-gray-200 dark:bg-slate-700 text-gray-700 dark:text-slate-300 hover:bg-gray-300 dark:hover:bg-slate-600";

    tabDrivers.addEventListener("click", () => {
    panelDrivers.classList.remove("hidden");
    panelConstructors.classList.add("hidden");
    tabDrivers.className = `px-3 py-1 text-xs font-semibold rounded-full transition-colors ${activeTab}`;
    tabConstructors.className = `px-3 py-1 text-xs font-semibold rounded-full transition-colors ${inactiveTab}`;
    });

    tabConstructors.addEventListener("click", () => {
    panelConstructors.classList.remove("hidden");
    panelDrivers.classList.add("hidden");
    tabConstructors.className = `px-3 py-1 text-xs font-semibold rounded-full transition-colors ${activeTab}`;
    tabDrivers.className = `px-3 py-1 text-xs font-semibold rounded-full transition-colors ${inactiveTab}`;
    });
  renderRace();
</script>