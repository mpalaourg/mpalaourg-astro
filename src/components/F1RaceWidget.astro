    yas_marina: `${BASE}/formula/circuit-images/yas_marina.png`,
    madring: `${BASE}/formula/circuit-images/madrid.svg`,
  };

  function formatLapTime(seconds: number | null | undefined): string {
    if (seconds == null || isNaN(seconds) || seconds <= 0) return "—";
    const m = Math.floor(seconds / 60);
    const s = seconds % 60;
    return `${m}:${s.toFixed(3).padStart(6, "0")}`;
  }

  // ─── Embedded data ────────────────────────────────────────────────────────
  const allRaces: any[] = JSON.parse(
    document.getElementById("f1-all-races")?.textContent ?? "[]"
  );
  const embeddedResults: Record<string, any[]> = JSON.parse(
    document.getElementById("f1-all-results")?.textContent ?? "{}"
  );
  const embeddedSessionKeys: Record<string, number> = JSON.parse(
    document.getElementById("f1-session-keys")?.textContent ?? "{}"
  );
  const TEAM_LOGOS: Record<string, string> = JSON.parse(
    document.getElementById("f1-team-logos")?.textContent ?? "{}"
  );

  // ─── SessionStorage caching ────────────────────────────────────────────────
  const SESSION_STORAGE_KEY = "f1-widget-results";
  
  function getCachedResults(): Record<string, any[]> {
    try {
      const cached = sessionStorage.getItem(SESSION_STORAGE_KEY);
      return cached ? JSON.parse(cached) : {};
    } catch {
      return {};
    }
  }
  
  function setCachedResult(key: string, data: any[]): void {
    try {
      const cached = getCachedResults();
      cached[key] = data;
      sessionStorage.setItem(SESSION_STORAGE_KEY, JSON.stringify(cached));
    } catch {
      // sessionStorage not available or quota exceeded
    }
  }
  
  // Merge embedded + cached results (cached takes precedence for runtime fetches)
  const allResults = { ...embeddedResults, ...getCachedResults() };
  const allSessionKeys = { ...embeddedSessionKeys, ...getCachedSessionKeys() };
  
  function getCachedSessionKeys(): Record<string, number> {
    try {
      const cached = sessionStorage.getItem("f1-widget-session-keys");
      return cached ? JSON.parse(cached) : {};
    } catch {
      return {};
    }
  }
  
  function setCachedSessionKey(key: string, sessionKey: number): void {
    try {
      const cached = getCachedSessionKeys();
      cached[key] = sessionKey;
      sessionStorage.setItem("f1-widget-session-keys", JSON.stringify(cached));
    } catch {
      // sessionStorage not available
    }
  }

  // ─── State ────────────────────────────────────────────────────────────────
  const now = Date.now();

  const nextRaceIndex = (() => {
    const idx = allRaces.findIndex(
      (r) => new Date(`${r.date}T${r.time ?? "00:00:00"}`).getTime() > now
    );
    return idx >= 0 ? idx : allRaces.length - 1;
  })();

  let currentRaceIndex = nextRaceIndex;
  let sessions: { label: string; date: Date; type: string }[] = [];
  let activeSessionIndex = 0;
  let countdownInterval: ReturnType<typeof setInterval> | null = null;

  // ─── Helpers ──────────────────────────────────────────────────────────────
  const pad = (n: number) => String(n).padStart(2, "0");

  function formatLocalDateTime(date: Date): string {
    const base = date.toLocaleString(undefined, {
      weekday: "short", day: "numeric", month: "short",
      hour: "2-digit", minute: "2-digit",
    });
    const off = -date.getTimezoneOffset();
    const sign = off >= 0 ? "+" : "-";
    const abs = Math.abs(off);
    const hh = Math.floor(abs / 60);
    const mm = abs % 60;
    const utc =
      mm === 0
        ? `UTC${sign}${hh}`
        : `UTC${sign}${pad(hh)}:${pad(mm)}`;
    return `${base} (${utc})`;
  }

  function buildSessions(race: any): { label: string; date: Date; type: string }[] {
    return [
      { label: "FP1",           type: "fp1",              obj: race.FirstPractice },
      { label: "FP2",           type: "fp2",              obj: race.SecondPractice },
      { label: "FP3",           type: "fp3",              obj: race.ThirdPractice },
      { label: "Sprint Quali",  type: "sprint_qualifying", obj: race.SprintQualifying },
      { label: "Sprint",        type: "sprint",           obj: race.Sprint },
      { label: "Qualifying",    type: "qualifying",       obj: race.Qualifying },
      { label: "Race",          type: "race",             obj: { date: race.date, time: race.time } },
    ]
      .filter((s) => s.obj?.date)
      .map((s) => ({
        label: s.label,
        type: s.type,
        date: s.obj.time
          ? new Date(`${s.obj.date}T${s.obj.time}`)
          : new Date(`${s.obj.date}T00:00:00`),
      }))
      .sort((a, b) => a.date.getTime() - b.date.getTime());
  }

  // ─── Medal / podium styling ───────────────────────────────────────────────
  const MEDAL_CARD = [
    "from-yellow-400/20 to-yellow-300/10 border-yellow-400/40 dark:from-yellow-500/20 dark:border-yellow-500/40",
    "from-slate-300/30 to-slate-200/10 border-slate-300/50 dark:from-slate-400/20 dark:border-slate-400/40",
    "from-orange-400/20 to-orange-300/10 border-orange-400/40 dark:from-orange-500/20 dark:border-orange-500/40",
  ];
  const MEDAL_NUM = [
    "text-yellow-500 dark:text-yellow-400",
    "text-slate-500 dark:text-slate-300",
    "text-orange-500 dark:text-orange-400",
  ];
  const TROPHY = ["🥇", "🥈", "🥉"];

  // ─── Logo helper ──────────────────────────────────────────────────────────
  function logoImg(constructorId: string, name: string) {
    const src = TEAM_LOGOS[constructorId];
    return src
      ? `<img src="${src}" alt="${name}" class="h-3.5 w-5 object-contain shrink-0 inline-block"/>`
      : `<span class="inline-block h-2.5 w-2.5 rounded-full bg-slate-400 shrink-0"></span>`;
  }

  // For OpenF1 rows (team name string, no constructorId)
  function logoByTeamName(teamName: string) {
    // Best-effort match by lowercasing team name fragments
    const t = teamName.toLowerCase();
    const id =
      t.includes("red bull") ? "red_bull"
      : t.includes("ferrari") ? "ferrari"
      : t.includes("mercedes") ? "mercedes"
      : t.includes("mclaren") ? "mclaren"
      : t.includes("alpine") ? "alpine"
      : t.includes("aston") ? "aston_martin"
      : t.includes("williams") ? "williams"
      : t.includes("haas") ? "haas"
      : t.includes("rb") || t.includes("racing bulls") ? "rb"
      : t.includes("audi") || t.includes("sauber") ? "audi"
      : t.includes("cadillac") || t.includes("andretti") ? "cadillac"
      : "";
    return logoImg(id, teamName);
  }

  // ─── Results renderers ────────────────────────────────────────────────────

  /** Top-3 podium cards — works for both OpenF1 and Jolpica rows */
  function podiumCards(
    top3: any[],
    getName: (r: any) => string,
    getNumber: (r: any) => string,
    getTeam: (r: any) => string,
    getTeamId: (r: any) => string,
    getTime: (r: any) => string
  ): string {
    if (!top3.length)
      return `<p class="text-xs text-gray-400 dark:text-slate-500 italic">No results yet.</p>`;

    return `<div class="flex gap-2">${top3
      .slice(0, 3)
      .map(
        (r, i) => `
      <div class="flex-1 min-w-0 rounded-xl border bg-gradient-to-b p-2.5 ${MEDAL_CARD[i]}">
        <div class="flex items-center gap-1 mb-1.5">
          <span class="text-base leading-none">${TROPHY[i]}</span>
          <span class="text-xs font-bold ${MEDAL_NUM[i]} tabular-nums ml-auto">#${getNumber(r)}</span>
        </div>
        <p class="text-xs font-bold leading-tight truncate text-gray-900 dark:text-white">${getName(r)}</p>
        <div class="flex items-center gap-1 mt-1">
          ${logoByTeamName(getTeam(r)) || logoImg(getTeamId(r), getTeam(r))}
          <span class="text-[10px] text-gray-500 dark:text-slate-400 truncate">${getTeam(r)}</span>
        </div>
        <p class="text-[10px] font-mono text-gray-600 dark:text-slate-300 mt-1.5 tabular-nums">${getTime(r)}</p>
      </div>`
      )
      .join("")}</div>`;
  }

  // OpenF1 practice top-3
  function renderOpenF1Podium(rows: any[]): string {
    return podiumCards(
      rows.slice(0, 3),
      (r) => r.name,
      (r) => String(r.driverNumber),
      (r) => r.teamName,
      (_r) => "", // no constructorId — logoByTeamName handles it
      (r) => r.lapTime
    );
  }

  // Jolpica qualifying top-3
  function renderJolpicaQualiPodium(rows: any[]): string {
    return podiumCards(
      rows.slice(0, 3),
      (r) => `${r.Driver.givenName[0]}. ${r.Driver.familyName}`,
      (r) => r.Driver.permanentNumber ?? "",
      (r) => r.Constructor?.name ?? "",
      (r) => r.Constructor?.constructorId ?? "",
      (r) => r.Q3 ?? r.Q2 ?? r.Q1 ?? "—"
    );
  }

  // Jolpica race/sprint top-3
  function renderJolpicaRacePodium(rows: any[]): string {
    return podiumCards(
      rows.slice(0, 3),
      (r) => `${r.Driver.givenName[0]}. ${r.Driver.familyName}`,
      (r) => r.Driver.permanentNumber ?? "",
      (r) => r.Constructor?.name ?? "",
      (r) => r.Constructor?.constructorId ?? "",
      (r) => r.Time?.time ?? r.status ?? "—"
