---
import {
  getSeasonRaces,
  getDriverStandings,
  getConstructorStandings,
  getJolpicaQualifying,
  getJolpicaRaceResults,
  getJolpicaSprintResults,
  getOpenF1SessionResults,
  PRACTICE_SESSION_NAMES,
  type OpenF1ResultRow,
} from "../utils/f1";

// ─── Base data ────────────────────────────────────────────────────────────────
const [races, driverStandings, constructorStandings] = await Promise.all([
  getSeasonRaces(),
  getDriverStandings(),
  getConstructorStandings(),
]);

const totalConstructorPts = constructorStandings.reduce(
  (s, c) => s + parseFloat(c.points),
  0
);
const enrichedConstructors = constructorStandings.map((c) => {
  const drivers = driverStandings
    .filter((d) => d.Constructors.some((co) => co.name === c.Constructor.name))
    .map((d) => ({
      name: `${d.Driver.givenName[0]}. ${d.Driver.familyName}`,
      points: d.points,
      pct:
        totalConstructorPts > 0
          ? ((parseFloat(d.points) / parseFloat(c.points)) * 100).toFixed(0)
          : "0",
    }));
  return { ...c, drivers };
});

// ─── Build results map at build time ─────────────────────────────────────────
/**
 * Key pattern: "${season}-${round}-${type}"
 * type: "fp1" | "fp2" | "fp3" | "qualifying" | "sprint_qualifying" |
 *       "sprint" | "race"
 */
const allResults: Record<string, any> = {};
const allSessionKeys: Record<string, number> = {}; // fp sessions only
const now = new Date();

function sessionDateMs(obj: { date: string; time?: string }) {
  return new Date(`${obj.date}T${obj.time ?? "00:00:00"}`).getTime();
}

function isPast(ms: number) {
  // 30-min grace so API has time to publish
  return ms < Date.now() - 30 * 60 * 1000;
}

// Process races sequentially to avoid hammering OpenF1
for (const race of races) {
  const season = race.season as string;
  const round = race.round as string;
  const country = race.Circuit.Location.country as string;
  const year = parseInt(season);

  const sessions = [
    { key: "fp1", num: 1, obj: race.FirstPractice },
    { key: "fp2", num: 2, obj: race.SecondPractice },
    { key: "fp3", num: 3, obj: race.ThirdPractice },
    { key: "sprint_qualifying", obj: race.SprintQualifying },
    { key: "sprint", obj: race.Sprint },
    { key: "qualifying", obj: race.Qualifying },
    { key: "race", obj: { date: race.date, time: race.time } },
  ];

  for (const session of sessions) {
    if (!session.obj?.date) continue;
    const ms = sessionDateMs(session.obj);
    if (!isPast(ms)) continue; // only fetch past sessions

    const cacheKey = `${season}-${round}-${session.key}`;

    try {
      if (
        session.key === "fp1" ||
        session.key === "fp2" ||
        session.key === "fp3"
      ) {
        const num = session.num as 1 | 2 | 3;
        // Resolve and store the session key for client-side fallback
        const openF1Country =
          (await import("../utils/f1")).JOLPICA_TO_OPENF1_COUNTRY[country] ?? country;
        const skRes = await fetch(
          `https://api.openf1.org/v1/sessions?year=${year}&country_name=${encodeURIComponent(openF1Country)}&session_name=${encodeURIComponent(PRACTICE_SESSION_NAMES[num])}`
        );
        if (skRes.ok) {
          const skData = await skRes.json();
          if (skData?.[0]?.session_key) {
            allSessionKeys[cacheKey] = skData[0].session_key;
          }
        }
        const rows = await getOpenF1SessionResults(
          year,
          country,
          PRACTICE_SESSION_NAMES[num],
          session.obj.date
        );
        allResults[cacheKey] = rows;
      } else if (session.key === "sprint_qualifying") {
        const rows = await getOpenF1SessionResults(
          year,
          country,
          "Sprint Qualifying",
          session.obj.date,
          true // isQualifying
        );
        allResults[cacheKey] = rows;
      } else if (session.key === "qualifying") {
        const data = await getJolpicaQualifying(season, round);
        allResults[cacheKey] = data ?? [];
      } else if (session.key === "sprint") {
        const data = await getJolpicaSprintResults(season, round);
        allResults[cacheKey] = data ?? [];
      } else if (session.key === "race") {
        const data = await getJolpicaRaceResults(season, round);
        allResults[cacheKey] = data ?? [];
      }
    } catch (e) {
      console.warn(`Failed to fetch ${cacheKey}:`, e);
      allResults[cacheKey] = [];
    }
  }
}

// ─── Static assets ────────────────────────────────────────────────────────────
const BASE = import.meta.env.BASE_URL.replace(/\/$/, "");
const TEAM_LOGOS: Record<string, string> = {
  mercedes: `${BASE}/formula/team-logos/mercedes.svg`,
  ferrari: `${BASE}/formula/team-logos/ferrari.svg`,
  red_bull: `${BASE}/formula/team-logos/red_bull.png`,
  mclaren: `${BASE}/formula/team-logos/mclaren.png`,
  alpine: `${BASE}/formula/team-logos/alpine.svg`,
  aston_martin: `${BASE}/formula/team-logos/aston_martin.svg`,
  williams: `${BASE}/formula/team-logos/williams.svg`,
  haas: `${BASE}/formula/team-logos/haas.svg`,
  rb: `${BASE}/formula/team-logos/rb.svg`,
  audi: `${BASE}/formula/team-logos/audi.svg`,
  cadillac: `${BASE}/formula/team-logos/cadillac.svg`,
};

interface Props {
  lang?: "en" | "el";
}
const { lang = "en" } = Astro.props;

const t = {
  en: {
    nextRace: "Next Race",
    pastRace: "Past Race",
    upcoming: "Upcoming",
    round: "Round",
    drivers: "Drivers",
    constructors: "Constructors",
    noRaceData: "No race data available.",
    seasonNotStarted: "Season hasn't started yet",
    driverStandingsEmpty: "Driver standings will appear after Round 1",
    constructorStandingsEmpty:
      "Constructor standings will appear after Round 1",
    days: "days",
    hrs: "hrs",
    min: "min",
    sec: "sec",
    prev: "Prev",
    next: "Next",
    driver: "Driver",
    constructor: "Constructor",
    number: "No",
    points: "Points",
    wins: "Wins",
    pts: "pts",
  },
  el: {
    nextRace: "Επόμενος Αγώνας",
    pastRace: "Προηγούμενος Αγώνας",
    upcoming: "Προσεχής",
    round: "Γύρος",
    drivers: "Οδηγοί",
    constructors: "Κατασκευαστές",
    noRaceData: "Δεν υπάρχουν διαθέσιμα δεδομένα αγώνα.",
    seasonNotStarted: "Η σεζόν δεν έχει ξεκινήσει ακόμα",
    driverStandingsEmpty: "Η κατάταξη οδηγών θα εμφανιστεί μετά τον 1ο γύρο",
    constructorStandingsEmpty:
      "Η κατάταξη κατασκευαστών θα εμφανιστεί μετά τον 1ο γύρο",
    days: "μέρες",
    hrs: "ώρες",
    min: "λεπτά",
    sec: "δευτ",
    prev: "Προηγ",
    next: "Επόμενο",
    driver: "Οδηγός",
    constructor: "Κατασκευαστής",
    number: "Αρ",
    points: "Βαθμοί",
    wins: "Νίκες",
    pts: "βαθ",
  },
} as const;

const T = t[lang];
---

{
  races.length > 0 ? (
    <div
      id="f1-widget"
      data-labels={JSON.stringify({
        nextRace: T.nextRace,
        pastRace: T.pastRace,
        upcoming: T.upcoming,
        round: T.round,
      })}
      class="rounded-xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-slate-800 p-5 shadow-sm"
    >
      {/* Embedded data blobs */}
      <script
        id="f1-all-races"
        type="application/json"
        set:html={JSON.stringify(races)}
      />
      <script
        id="f1-all-results"
        type="application/json"
        set:html={JSON.stringify(allResults)}
      />
      <script
        id="f1-session-keys"
        type="application/json"
        set:html={JSON.stringify(allSessionKeys)}
      />
      <script
        id="f1-team-logos"
        type="application/json"
        set:html={JSON.stringify(TEAM_LOGOS)}
      />

      <div id="f1-content">
        {/* Header */}
        <div class="flex items-start justify-between gap-4 mb-4">
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2 mb-1 flex-wrap">
              <span
                id="f1-badge"
                class="text-xs font-bold px-2 py-0.5 rounded-full bg-red-600 text-white uppercase tracking-wide"
              >
                Next Race
              </span>
              <span
                id="f1-round"
                class="text-xs text-gray-500 dark:text-slate-400"
              />
            </div>
            <h3 id="f1-race-name" class="text-xl font-bold" />
            <p
              id="f1-circuit-name"
              class="text-sm text-gray-500 dark:text-slate-400"
            />
          </div>
          <div id="f1-flag" class="text-4xl shrink-0" />
        </div>

        {/* Sessions + circuit image */}
        <div class="flex flex-col md:flex-row gap-4 mb-4">
          <div class="flex-1 min-w-0">
            <div class="flex flex-wrap gap-1 mb-3" id="f1-session-tabs" />
            <div class="rounded-lg bg-slate-100 dark:bg-slate-700/50 p-3">
              <p
                id="f1-session-label"
                class="text-xs font-semibold uppercase tracking-wide text-gray-500 dark:text-slate-400 mb-1"
              />
              <p
                id="f1-session-datetime"
                class="text-xs text-gray-500 dark:text-slate-400 mb-2"
              />
              {/* Countdown */}
              <div id="f1-countdown" class="flex gap-3">
                {(
                  [
                    [T.days, "days"],
                    [T.hrs, "hours"],
                    [T.min, "mins"],
                    [T.sec, "secs"],
                  ] as const
                ).map(([label, id], i, arr) => (
                  <>
                    <div class="text-center">
                      <div
                        id={`cd-${id}`}
                        class="text-2xl font-bold font-mono tabular-nums"
                      >
                        --
                      </div>
                      <div class="text-xs text-gray-500 dark:text-slate-400">
                        {label}
                      </div>
                    </div>
                    {i < arr.length - 1 && (
                      <div class="text-xl font-bold self-start mt-1">:</div>
                    )}
                  </>
                ))}
              </div>
              {/* Results panel */}
              <div id="f1-results-panel" class="hidden mt-3" />
            </div>
          </div>

          {/* Circuit image */}
          <div class="md:w-48 shrink-0 flex items-center justify-center rounded-xl bg-slate-100 dark:bg-slate-700/60 p-3">
            <img
              id="f1-circuit-img"
              src=""
              alt="Circuit map"
              class="max-h-40 max-w-full object-contain hidden"
            />
          </div>
        </div>

        {/* Navigation */}
        <div class="flex items-center justify-between mt-2 gap-2">
          <button
            id="f1-prev"
            aria-label="Previous race"
            class="flex items-center gap-1 px-3 py-1.5 rounded-lg text-sm font-medium
                   bg-gray-100 dark:bg-slate-700 text-gray-700 dark:text-slate-300
                   hover:bg-gray-200 dark:hover:bg-slate-600 disabled:opacity-30
                   disabled:cursor-not-allowed transition-colors shrink-0"
          >
            <svg
              class="w-4 h-4"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M15 19l-7-7 7-7"
              />
            </svg>
            {T.prev}
          </button>
          <div
            id="f1-dots"
            class="flex gap-1 flex-wrap justify-center flex-1"
          />
          <button
            id="f1-next"
            aria-label="Next race"
            class="flex items-center gap-1 px-3 py-1.5 rounded-lg text-sm font-medium
                   bg-gray-100 dark:bg-slate-700 text-gray-700 dark:text-slate-300
                   hover:bg-gray-200 dark:hover:bg-slate-600 disabled:opacity-30
                   disabled:cursor-not-allowed transition-colors shrink-0"
          >
            {T.next}
            <svg
              class="w-4 h-4"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M9 5l7 7-7 7"
              />
            </svg>
          </button>
        </div>
      </div>

      {/* Standings */}
      <div class="mt-5 border-t border-gray-200 dark:border-gray-700 pt-4">
        <div class="flex gap-2 mb-3">
          <button
            id="tab-drivers"
            class="px-3 py-1 text-xs font-semibold rounded-full bg-red-600 text-white transition-colors"
          >
            {T.drivers}
          </button>
          <button
            id="tab-constructors"
            class="px-3 py-1 text-xs font-semibold rounded-full bg-gray-200 dark:bg-slate-700 text-gray-700 dark:text-slate-300 hover:bg-gray-300 dark:hover:bg-slate-600 transition-colors"
          >
            {T.constructors}
          </button>
        </div>

        {/* Driver standings */}
        <div id="standings-drivers">
          {driverStandings.length > 0 ? (
            <div class="overflow-hidden rounded-lg border border-gray-200 dark:border-gray-700">
              <div class="grid grid-cols-[2rem_2rem_1fr_3.5rem_2.5rem] gap-x-2 px-3 py-1.5 bg-slate-100 dark:bg-slate-700/80 border-b border-gray-200 dark:border-gray-700">
                <span class="text-xs font-semibold text-gray-400 dark:text-slate-500 text-center">
                  #
                </span>
                <span class="text-xs font-semibold text-gray-400 dark:text-slate-500 text-center">
                  {T.number}
                </span>
                <span class="text-xs font-semibold text-gray-400 dark:text-slate-500">
                  {T.driver}
                </span>
                <span class="text-xs font-semibold text-gray-400 dark:text-slate-500 text-right">
                  {T.points}
                </span>
                <span class="text-xs font-semibold text-gray-400 dark:text-slate-500 text-right">
                  {T.wins}
                </span>
              </div>
              <div class="max-h-64 overflow-y-auto divide-y divide-gray-100 dark:divide-slate-700/50">
                {driverStandings.map((d, i) => {
                  const cid = d.Constructors[0]?.constructorId ?? "";
                  const logo = TEAM_LOGOS[cid];
                  return (
                    <div
                      class={[
                        "grid grid-cols-[2rem_2rem_1fr_3.5rem_2.5rem] gap-x-2 px-3 py-2 items-center transition-colors hover:bg-red-50 dark:hover:bg-slate-700/40",
                        i % 2 === 0
                          ? "bg-white dark:bg-slate-800"
                          : "bg-slate-50 dark:bg-slate-700/40",
                      ].join(" ")}
                    >
                      <span class="text-xs text-gray-400 dark:text-slate-500 font-mono text-center">
                        {d.position}
                      </span>
                      <span class="text-xs font-bold text-center bg-slate-200 dark:bg-slate-700 rounded px-1 py-0.5 tabular-nums">
                        {d.Driver.permanentNumber}
                      </span>
                      <span class="flex items-center gap-2 min-w-0">
                        {logo ? (
                          <img
                            src={logo}
                            alt={d.Constructors[0]?.name}
                            class="h-4 w-6 object-contain shrink-0"
                          />
                        ) : (
                          <span class="h-3 w-3 rounded-full shrink-0 bg-slate-400" />
                        )}
                        <span class="truncate text-sm font-medium">
                          {d.Driver.givenName[0]}. {d.Driver.familyName}
                        </span>
                      </span>
                      <span class="text-sm font-bold tabular-nums text-right">
                        {d.points}
                      </span>
                      <span class="text-xs text-gray-400 dark:text-slate-500 text-right tabular-nums">
                        {d.wins}
                      </span>
                    </div>
                  );
                })}
              </div>
            </div>
          ) : (
            <div class="flex flex-col items-center justify-center py-8 text-center gap-2">
              <span class="text-2xl">🏎️</span>
              <p class="text-sm font-medium text-gray-500 dark:text-slate-400">
                {T.seasonNotStarted}
              </p>
              <p class="text-xs text-gray-400 dark:text-slate-500">
                {T.driverStandingsEmpty}
              </p>
            </div>
          )}
        </div>

        {/* Constructor standings */}
        <div id="standings-constructors" class="hidden">
          {enrichedConstructors.length > 0 ? (
            <div class="overflow-hidden rounded-lg border border-gray-200 dark:border-gray-700">
              <div class="grid grid-cols-[2rem_1fr_3.5rem_2.5rem] gap-x-2 px-3 py-1.5 bg-slate-100 dark:bg-slate-700/80 border-b border-gray-200 dark:border-gray-700">
                <span class="text-xs font-semibold text-gray-400 dark:text-slate-500 text-center">
                  #
                </span>
                <span class="text-xs font-semibold text-gray-400 dark:text-slate-500">
                  {T.constructor}
                </span>
                <span class="text-xs font-semibold text-gray-400 dark:text-slate-500 text-right">
                  {T.points}
                </span>
                <span class="text-xs font-semibold text-gray-400 dark:text-slate-500 text-right">
                  {T.wins}
                </span>
              </div>
              <div class="max-h-64 overflow-y-auto divide-y divide-gray-100 dark:divide-slate-700/50">
                {enrichedConstructors.map((c, i) => {
                  const logo = TEAM_LOGOS[c.Constructor.constructorId];
                  return (
                    <div
                      class={
                        i % 2 === 0
                          ? "bg-white dark:bg-slate-800"
                          : "bg-slate-50 dark:bg-slate-700/40"
                      }
                    >
                      <div class="grid grid-cols-[2rem_1fr_3.5rem_2.5rem] gap-x-2 px-3 py-2 items-center transition-colors hover:bg-red-50 dark:hover:bg-slate-700/40">
                        <span class="text-xs text-gray-400 dark:text-slate-500 font-mono text-center">
                          {c.position}
                        </span>
                        <span class="flex items-center gap-2 min-w-0">
                          {logo ? (
                            <img
                              src={logo}
                              alt={c.Constructor.name}
                              class="h-4 w-6 object-contain shrink-0"
                            />
                          ) : (
                            <span class="h-3 w-3 rounded-full shrink-0 bg-slate-400" />
                          )}
                          <span class="truncate text-sm font-semibold">
                            {c.Constructor.name}
                          </span>
                        </span>
                        <span class="text-sm font-bold tabular-nums text-right">
                          {c.points}
                        </span>
                        <span class="text-xs text-gray-400 dark:text-slate-500 text-right tabular-nums">
                          {c.wins}
                        </span>
                      </div>
                      {c.drivers && c.drivers.length > 0 && (
                        <div class="pb-1.5 px-3 ml-8 space-y-0.5">
                          {c.drivers.map((drv) => (
                            <div class="flex items-center gap-2 text-xs text-gray-500 dark:text-slate-400">
                              <span class="flex-1 truncate">{drv.name}</span>
                              <span class="tabular-nums font-medium">
                                {drv.points} {T.pts}
                              </span>
                              <div class="w-20 flex items-center gap-1">
                                <div class="flex-1 h-1 rounded-full bg-slate-200 dark:bg-slate-600 overflow-hidden">
                                  <div
                                    class="h-full rounded-full bg-red-400 dark:bg-red-500"
                                    style={`width: ${drv.pct}%`}
                                  />
                                </div>
                                <span class="w-7 text-right tabular-nums text-gray-400 dark:text-slate-500">
                                  {drv.pct}%
                                </span>
                              </div>
                            </div>
                          ))}
                        </div>
                      )}
                    </div>
                  );
                })}
              </div>
            </div>
          ) : (
            <div class="flex flex-col items-center justify-center py-8 text-center gap-2">
              <span class="text-2xl">🏗️</span>
              <p class="text-sm font-medium text-gray-500 dark:text-slate-400">
                {T.seasonNotStarted}
              </p>
              <p class="text-xs text-gray-400 dark:text-slate-500">
                {T.constructorStandingsEmpty}
              </p>
            </div>
          )}
        </div>
      </div>
    </div>
  ) : (
    <div class="rounded-xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-slate-800 p-5 text-sm text-gray-500 dark:text-slate-400">
      {T.noRaceData}
    </div>
  )
}

{/* ─── Modal ─────────────────────────────────────────────────────────────────── */}
<div
  id="f1-modal-backdrop"
  class="fixed inset-0 z-50 hidden items-center justify-center p-4"
  style="background: rgba(0,0,0,0.65); backdrop-filter: blur(3px);"
>
  <div
    id="f1-modal"
    class="relative w-full max-w-lg max-h-[85vh] flex flex-col rounded-2xl
           bg-white dark:bg-slate-800 shadow-2xl
           border border-gray-200 dark:border-gray-700 overflow-hidden"
  >
    <div class="flex items-center justify-between px-5 py-4 border-b border-gray-200 dark:border-gray-700 shrink-0">
      <h2
        id="f1-modal-title"
        class="text-base font-bold text-gray-900 dark:text-white"
      />
      <button
        id="f1-modal-close"
        aria-label="Close"
        class="rounded-lg p-1.5 text-gray-400 hover:text-gray-700 dark:hover:text-white
               hover:bg-gray-100 dark:hover:bg-slate-700 transition-colors"
      >
        <svg
          class="w-5 h-5"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M6 18L18 6M6 6l12 12"
          />
        </svg>
      </button>
    </div>
    <div id="f1-modal-body" class="overflow-y-auto flex-1 px-5 py-4 space-y-4" />
  </div>
</div>

<script>
  // ─── Constants ────────────────────────────────────────────────────────────
  const COUNTRY_FLAGS: Record<string, string> = {
    Australia: "🇦🇺", Bahrain: "🇧🇭", "Saudi Arabia": "🇸🇦",
    Japan: "🇯🇵", China: "🇨🇳", USA: "🇺🇸", "United States": "🇺🇸",
    Italy: "🇮🇹", Monaco: "🇲🇨", Canada: "🇨🇦", Spain: "🇪🇸",
    Austria: "🇦🇹", UK: "🇬🇧", "United Kingdom": "🇬🇧",
    Hungary: "🇭🇺", Belgium: "🇧🇪", Netherlands: "🇳🇱",
    Azerbaijan: "🇦🇿", Singapore: "🇸🇬", Mexico: "🇲🇽",
    Brazil: "🇧🇷", "Las Vegas": "🇺🇸", Qatar: "🇶🇦",
    UAE: "🇦🇪", "Abu Dhabi": "🇦🇪",
  };

  const BASE = import.meta.env.BASE_URL.replace(/\/$/, "");
  const CIRCUIT_IMAGES: Record<string, string> = {
    albert_park: `${BASE}/formula/circuit-images/albert_park.svg`,
    bahrain: `${BASE}/formula/circuit-images/bahrain.svg`,
