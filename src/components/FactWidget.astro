---
// Random Fact Widget
interface Props {
  lang?: "en" | "el";
}

const { lang = "en" } = Astro.props;

const t = {
  en: {
    title: "Did You Know?",
    newFact: "New Fact",
  },
  el: {
    title: "Ξέρατε Ότι;",
    newFact: "Νέο Γεγονός",
  },
} as const;

const T = t[lang];
---

<div class="fact-widget group relative" data-lang={lang}>
  {/* Compact View */}
  <div class="flex items-center gap-2 px-3 py-1.5 rounded-full bg-gradient-to-r from-yellow-500/10 via-orange-400/10 to-amber-400/10 border border-yellow-200/50 dark:border-yellow-700/50 hover:border-yellow-400 dark:hover:border-yellow-500 transition-all cursor-pointer">
    <span class="text-base">💡</span>
    <span class="fact-preview text-xs font-medium text-gray-600 dark:text-slate-400 truncate max-w-[120px]">Loading...</span>
  </div>

  {/* Expanded Info on Hover */}
  <div class="fact-popup absolute top-full left-0 mt-2 w-72 p-4 rounded-xl bg-white dark:bg-slate-800 border border-gray-200 dark:border-gray-700 shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all z-50">
    {/* Header */}
    <div class="flex items-center justify-between mb-3">
      <div class="flex items-center gap-2">
        <span class="text-xl">💡</span>
        <div class="font-bold text-sm">{T.title}</div>
      </div>
      <button class="fact-refresh text-xs text-yellow-600 dark:text-yellow-400 hover:underline cursor-pointer">
        🔄 {T.newFact}
      </button>
    </div>

    {/* Fact */}
    <div class="fact-content text-sm text-gray-700 dark:text-slate-300 leading-relaxed">
      Loading interesting fact...
    </div>

    <div class="fact-source text-[10px] text-gray-400 mt-3 text-right">--</div>
  </div>
</div>

<style>
  .fact-widget {
    position: relative;
  }
</style>

<script is:inline>
  async function fetchFact(widget) {
    const lang = widget.dataset.lang;
    
    try {
      // Try multiple fact APIs
      let fact = '';
      let source = '';
      
      // API 1: Useless Facts (no key needed)
      try {
        const res = await fetch('https://uselessfacts.jsph.pl/random.json?language=en');
        if (res.ok) {
          const data = await res.json();
          fact = data.text;
          source = 'uselessfacts.jsph.pl';
        }
      } catch (e) {
        // Try backup API
      }
      
      // API 2: Numbers API (if first fails)
      if (!fact) {
        try {
          const res = await fetch('http://numbersapi.com/random/trivia');
          if (res.ok) {
            fact = await res.text();
            source = 'numbersapi.com';
          }
        } catch (e) {
          // Use fallback
        }
      }
      
      // Fallback facts if APIs fail
      if (!fact) {
        const fallbackFacts = [
          "Honey never spoils. Archaeologists have found pots of honey in ancient Egyptian tombs that are over 3,000 years old and still edible.",
          "Octopuses have three hearts, nine brains, and blue blood.",
          "The shortest war in history was between Britain and Zanzibar on August 27, 1896. Zanzibar surrendered after 38 minutes.",
          "Bananas are berries, but strawberries aren't.",
          "A day on Venus is longer than a year on Venus.",
          "The Great Wall of China is not visible from space with the naked eye.",
          "Wombat poop is cube-shaped.",
          "The unicorn is the national animal of Scotland.",
        ];
        fact = fallbackFacts[Math.floor(Math.random() * fallbackFacts.length)];
        source = 'fallback';
      }
      
      // Update UI
      const previewEl = widget.querySelector('.fact-preview');
      const contentEl = widget.querySelector('.fact-content');
      const sourceEl = widget.querySelector('.fact-source');
      
      if (previewEl) {
        // Show first 30 chars as preview
        previewEl.textContent = fact.substring(0, 30) + '...';
      }
      
      if (contentEl) contentEl.textContent = fact;
      if (sourceEl) {
        sourceEl.textContent = source === 'fallback' 
          ? (lang === 'el' ? 'Τυχαίο γεγονός' : 'Random fact')
          : `Source: ${source}`;
      }
      
    } catch (err) {
      console.error('Fact fetch error:', err);
      const previewEl = widget.querySelector('.fact-preview');
      if (previewEl) previewEl.textContent = lang === 'el' ? 'Σφάλμα' : 'Error';
    }
  }

  // Initialize all fact widgets
  document.querySelectorAll('.fact-widget').forEach(widget => {
    fetchFact(widget);
    
    // Add refresh button handler
    const refreshBtn = widget.querySelector('.fact-refresh');
    if (refreshBtn) {
      refreshBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        fetchFact(widget);
      });
    }
  });
</script>
