---
// Music Widget - Last.fm Integration
interface Props {
  lang?: "en" | "el";
  username?: string;
}

const { lang = "en", username = "mpalaourg" } = Astro.props;

const t = {
  en: {
    listening: "Listening",
    lastPlayed: "Last played",
    scrobbles: "scrobbles",
    now: "Now",
  },
  el: {
    listening: "Ακούω",
    lastPlayed: "Τελευταίο",
    scrobbles: "αναπαραγωγές",
    now: "Τώρα",
  },
} as const;

const T = t[lang];
---

<div class="music-widget group" data-username={username} data-lang={lang}>
  {/* Compact View */}
  <a href={`https://www.last.fm/user/${username}`} target="_blank" rel="noopener" class="block">
    <div class="flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-gradient-to-r from-green-500/10 via-emerald-400/10 to-teal-400/10 border border-green-200/50 dark:border-green-700/50 hover:border-green-400 dark:hover:border-green-500 transition-all">
      <div class="relative">
        <img src="" alt="" class="music-cover w-5 h-5 rounded-full object-cover opacity-0 transition-opacity" />
        <div class="music-placeholder absolute inset-0 flex items-center justify-center text-xs">🎵</div>
        <div class="music-playing-indicator absolute -bottom-0.5 -right-0.5 w-2 h-2 bg-red-500 rounded-full hidden animate-pulse"></div>
      </div>
      <span class="music-track text-xs font-medium max-w-[100px] truncate opacity-50">--</span>
    </div>
  </a>

  {/* Expanded Info on Hover */}
  <div class="absolute top-full left-0 mt-2 w-56 p-4 rounded-xl bg-white dark:bg-slate-800 border border-gray-200 dark:border-gray-700 shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all z-50 pointer-events-none group-hover:pointer-events-auto">
    <div class="flex gap-3">
      <img src="" alt="" class="music-cover-expanded w-16 h-16 rounded-lg object-cover opacity-0" />
      <div class="flex-1 min-w-0">
        <div class="music-status text-[10px] text-gray-500 uppercase tracking-wider mb-1">{T.lastPlayed}</div>
        <div class="music-track-expanded text-sm font-medium truncate mb-0.5">--</div>
        <div class="music-artist text-xs text-gray-500 truncate mb-2">--</div>
        <div class="flex items-center gap-2 text-[10px] text-gray-400">
          <span class="music-scrobbles">-- {T.scrobbles}</span>
        </div>
      </div>
    </div>
    
    <a 
      href={`https://www.last.fm/user/${username}`} 
      target="_blank" 
      rel="noopener"
      class="mt-3 block w-full py-2 text-center text-xs font-medium text-green-700 dark:text-green-400 bg-green-100 dark:bg-green-900/30 rounded-lg hover:bg-green-200 dark:hover:bg-green-800/50 transition-colors"
    >
      View Profile →
    </a>
  </div>
</div>

<style>
  .music-widget {
    position: relative;
  }
</style>

<script is:inline>
  async function fetchMusic(widget) {
    const username = widget.dataset.username;
    const lang = widget.dataset.lang;
    
    try {
      const res = await fetch(`/api/music?username=${username}`);
      if (!res.ok) throw new Error('Failed to fetch');
      const data = await res.json();
      
      const cover = widget.querySelector('.music-cover');
      const coverExpanded = widget.querySelector('.music-cover-expanded');
      const track = widget.querySelector('.music-track');
      const trackExpanded = widget.querySelector('.music-track-expanded');
      const artist = widget.querySelector('.music-artist');
      const status = widget.querySelector('.music-status');
      const indicator = widget.querySelector('.music-playing-indicator');
      const placeholder = widget.querySelector('.music-placeholder');
      const scrobbles = widget.querySelector('.music-scrobbles');
      
      if (data.track) {
        // Update track info
        track.textContent = data.track;
        track.classList.remove('opacity-50');
        trackExpanded.textContent = data.track;
        artist.textContent = data.artist;
        
        // Update status
        if (data.isPlaying) {
          status.textContent = lang === 'el' ? 'Τώρα' : 'Now';
          indicator.classList.remove('hidden');
        } else {
          status.textContent = lang === 'el' ? 'Τελευταίο' : 'Last played';
          indicator.classList.add('hidden');
        }
        
        // Update scrobbles
        if (data.scrobbles) {
          scrobbles.textContent = `${data.scrobbles.toLocaleString()} ${lang === 'el' ? 'αναπαραγωγές' : 'scrobbles'}`;
        }
        
        // Update cover images
        if (data.cover) {
          cover.src = data.cover;
          coverExpanded.src = data.cover;
          cover.classList.remove('opacity-0');
          coverExpanded.classList.remove('opacity-0');
          placeholder.classList.add('hidden');
        }
      }
    } catch (err) {
      console.error('Music fetch error:', err);
    }
  }

  // Initialize all music widgets
  document.querySelectorAll('.music-widget').forEach(widget => {
    fetchMusic(widget);
    // Refresh every 30 seconds
    setInterval(() => fetchMusic(widget), 30000);
  });
</script>
