---
// NASA APOD Widget - Astronomy Picture of the Day
interface Props {
  lang?: "en" | "el";
}

const { lang = "en" } = Astro.props;

const t = {
  en: {
    title: "Space Today",
    by: "by NASA",
    viewFull: "View Full Image",
  },
  el: {
    title: "Διάστημα Σήμερα",
    by: "από τη NASA",
    viewFull: "Προβολή Πλήρους Εικόνας",
  },
} as const;

const T = t[lang];
---

<div class="nasa-widget group relative" data-lang={lang}>
  {/* Compact View */}
  <div class="flex items-center gap-2 px-3 py-1.5 rounded-full bg-gradient-to-r from-indigo-500/10 via-purple-500/10 to-pink-500/10 border border-indigo-200/50 dark:border-indigo-700/50 hover:border-indigo-400 dark:hover:border-indigo-500 transition-all cursor-pointer">
    <span class="text-base">🚀</span>
    <span class="nasa-title text-xs font-medium text-gray-600 dark:text-slate-400 truncate max-w-[120px]">Loading...</span>
  </div>

  {/* Expanded Info on Hover */}
  <div class="nasa-popup absolute top-full left-0 mt-2 w-80 p-4 rounded-xl bg-white dark:bg-slate-800 border border-gray-200 dark:border-gray-700 shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all z-50">
    {/* Header */}
    <div class="flex items-center justify-between mb-3">
      <div class="flex items-center gap-2">
        <span class="text-xl">🚀</span>
        <div>
          <div class="font-bold text-sm">{T.title}</div>
          <div class="text-[10px] text-gray-500">{T.by}</div>
        </div>
      </div>
      <span class="nasa-date text-[10px] text-gray-400"></span>
    </div>

    {/* Image */}
    <div class="relative mb-3 rounded-lg overflow-hidden bg-gray-100 dark:bg-slate-700 aspect-video">
      <img src="" alt="" class="nasa-image w-full h-full object-cover" />
      <div class="absolute inset-0 flex items-center justify-center nasa-loading">
        <span class="text-2xl animate-pulse">🚀</span>
      </div>
    </div>

    {/* Title & Description */}
    <div class="space-y-2">
      <h3 class="nasa-image-title text-sm font-bold line-clamp-2">--</h3>
      <p class="nasa-explanation text-xs text-gray-600 dark:text-slate-400 line-clamp-3">--</p>
    </div>

    {/* Link */}
    <a href="" target="_blank" rel="noopener" class="nasa-link mt-3 block w-full py-2 text-center text-xs font-medium text-indigo-700 dark:text-indigo-400 bg-indigo-100 dark:bg-indigo-900/30 rounded-lg hover:bg-indigo-200 dark:hover:bg-indigo-800/50 transition-colors">
      {T.viewFull} →
    </a>
  </div>
</div>

<style>
  .nasa-widget {
    position: relative;
  }
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>

<script is:inline>
  async function fetchNASA(widget) {
    const lang = widget.dataset.lang;
    
    try {
      // NASA APOD API - no API key needed for demo key (limited requests)
      // For production, get free API key from: https://api.nasa.gov/
      const res = await fetch('https://api.nasa.gov/planetary/apod?api_key=DEMO_KEY');
      
      if (!res.ok) throw new Error('Failed to fetch');
      const data = await res.json();
      
      // Update compact view
      const titleEl = widget.querySelector('.nasa-title');
      if (titleEl) titleEl.textContent = data.title;
      
      // Update expanded view
      const dateEl = widget.querySelector('.nasa-date');
      const imageEl = widget.querySelector('.nasa-image');
      const loadingEl = widget.querySelector('.nasa-loading');
      const imageTitleEl = widget.querySelector('.nasa-image-title');
      const explanationEl = widget.querySelector('.nasa-explanation');
      const linkEl = widget.querySelector('.nasa-link');
      
      if (dateEl) {
        const date = new Date(data.date);
        dateEl.textContent = date.toLocaleDateString(lang === 'el' ? 'el-GR' : 'en-US', { 
          month: 'short', 
          day: 'numeric' 
        });
      }
      
      if (imageEl) {
        // Use HD image if available, otherwise regular
        imageEl.src = data.hdurl || data.url;
        imageEl.alt = data.title;
        imageEl.onload = () => {
          if (loadingEl) loadingEl.style.display = 'none';
        };
      }
      
      if (imageTitleEl) imageTitleEl.textContent = data.title;
      if (explanationEl) explanationEl.textContent = data.explanation;
      if (linkEl) linkEl.href = data.url;
      
    } catch (err) {
      console.error('NASA fetch error:', err);
      const titleEl = widget.querySelector('.nasa-title');
      if (titleEl) titleEl.textContent = lang === 'el' ? 'Σφάλμα' : 'Error';
    }
  }

  // Initialize all NASA widgets
  document.querySelectorAll('.nasa-widget').forEach(widget => {
    fetchNASA(widget);
    // Refresh every hour (APOD updates daily)
    setInterval(() => fetchNASA(widget), 3600000);
  });
</script>
