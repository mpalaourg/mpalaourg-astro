<div class="table-wrapper">
  <button class="copy-btn" aria-label="Copy table as text" title="Copy table">
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
      <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
    </svg>
    <span class="copy-label">Copy</span>
  </button>
  <table>
    <slot />
  </table>
</div>

<style>
  .table-wrapper {
    position: relative;
  }

  .copy-btn {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    display: flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.25rem 0.5rem;
    font-size: 0.75rem;
    background: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 0.375rem;
    cursor: pointer;
    opacity: 0;
    transition: opacity 0.2s ease;
    z-index: 10;
  }

  :global(.dark) .copy-btn {
    background: #1e293b;
    border-color: #475569;
    color: #e2e8f0;
  }

  .table-wrapper:hover .copy-btn {
    opacity: 1;
  }

  .copy-btn:hover {
    background: #f3f4f6;
  }

  :global(.dark) .copy-btn:hover {
    background: #334155;
  }

  table {
    width: 100%;
    border-collapse: collapse;
  }

  :global(table tbody tr:nth-child(odd)) {
    background-color: #f9fafb;
  }

  :global(table tbody tr:nth-child(even)) {
    background-color: #ffffff;
  }

  :global(.dark table tbody tr:nth-child(odd)) {
    background-color: #1e293b;
  }

  :global(.dark table tbody tr:nth-child(even)) {
    background-color: #0f172a;
  }

  :global(table tbody tr:hover) {
    background-color: #eff6ff;
  }

  :global(.dark table tbody tr:hover) {
    background-color: #334155;
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('.table-wrapper').forEach((wrapper) => {
    const btn = wrapper.querySelector<HTMLButtonElement>('.copy-btn');
    const table = wrapper.querySelector<HTMLTableElement>('table');
    const label = btn?.querySelector<HTMLSpanElement>('.copy-label');

    if (!btn || !table || !label) return;

    btn.addEventListener('click', () => {
      const rows = Array.from(table.querySelectorAll('tr'));
      const text = rows
        .map((row) =>
          Array.from(row.querySelectorAll('th, td'))
            .map((cell) => cell.textContent?.trim() ?? '')
            .join('\t')
        )
        .join('\n');

      navigator.clipboard.writeText(text).then(() => {
        label.textContent = 'Copied!';
        setTimeout(() => {
          label.textContent = 'Copy';
        }, 2000);
      });
    });
  });
</script>